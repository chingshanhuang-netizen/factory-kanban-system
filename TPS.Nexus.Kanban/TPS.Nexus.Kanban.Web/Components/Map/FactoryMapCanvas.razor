@inject IJSRuntime JS
@inject IEquipmentService EquipmentSvc
@inject ILayoutService LayoutSvc
@inject IAlarmService AlarmSvc
@inject IMapImportService MapImportSvc
@inject IFunctionPermissionService PermSvc
@inject IOptions<KanbanModuleOptions> ModuleOpts
@implements IAsyncDisposable

@* W-6: guard non-positive MapId — route param parsing can produce 0 on unexpected input *@
@if (MapId <= 0)
{
    <div style="padding:40px;text-align:center;color:#f44336">MapId 無效（值：@MapId）</div>
    return;
}

@* Wrapper is position:relative so absolute-positioned drawers stack within it —
   this keeps z-index resolution consistent in both normal and fullscreen modes. *@
<div id="kanban-fs-wrapper" style="display:flex;height:100%;background:#1a1a2e;position:relative">

    <div id="map-canvas"
         class="kanban-map-container @(IsEditMode ? "kanban-edit-mode" : "")"
         style="flex:1;min-width:0;height:100%;position:relative;overflow:hidden;">

        @* Virtual 1920×1080 canvas — everything inside scales proportionally *@
        <div class="kanban-virtual-canvas" style="@VirtCanvasStyle">

            <MapLayer Map="@CurrentMap" />

            <div class="kanban-equipment-layer">
                @foreach (var widget in Widgets.Where(w => GetEquipment(w.EquipmentId)?.MapName == CurrentMap?.Name))
                {
                    <EquipmentWidgetPanel
                        Widget="@widget"
                        EquipmentData="@GetEquipment(widget.EquipmentId)"
                        ActiveAlarm="@GetActiveAlarm(widget.EquipmentId)"
                        IsRunning="@GetIsRunning(widget.EquipmentId)"
                        OnClick="@((w) => HandleWidgetClick(w))"
                        OnHover="@((w) => HandleWidgetHover(w))"
                        OnHoverEnd="@HandleHoverEnd" />
                }
            </div>

            <EquipmentTooltip
                Widget="@HoveredWidget"
                EquipmentData="@GetEquipment(HoveredWidget?.EquipmentId ?? 0)"
                LatestData="@HoveredData" />

        </div>

        @* Fullscreen toggle — top right corner, z-index above drawers *@
        <button @onclick="ToggleFullscreen"
                title="@(_isFullscreen ? "退出全螢幕" : "全螢幕")"
                style="position:absolute;top:8px;right:8px;z-index:100;
                       background:rgba(0,0,0,.55);color:#ccc;border:1px solid #333;
                       border-radius:5px;padding:3px 8px;cursor:pointer;font-size:1em;
                       line-height:1.4;transition:background .15s">
            @(_isFullscreen ? "⊡" : "⛶")
        </button>

        @* Equipment palette toggle — edit mode only, z-index above drawers *@
        @if (IsEditMode)
        {
            <button @onclick="@(() => _equipDrawerOpen = !_equipDrawerOpen)"
                    title="@(_equipDrawerOpen ? "隱藏設備清單" : "顯示設備清單")"
                    style="position:absolute;top:8px;right:52px;z-index:100;
                           background:rgba(13,27,42,.85);color:#4fc3f7;
                           border:1px solid #1a3a5c;border-radius:5px;
                           padding:3px 10px;cursor:pointer;font-size:0.82em;
                           line-height:1.6;transition:background .15s">
                ⊞ 設備
            </button>
        }

    </div>

    @* ── Detail drawer (current value) ─────────────────────────────────────────
       position:absolute inside #kanban-fs-wrapper so it stacks correctly in both
       normal and fullscreen modes without z-index cross-context issues.        *@
    <EquipmentDetailDrawer
        @bind-IsOpen="DrawerOpen"
        Widget="@SelectedWidget"
        EquipmentData="@GetEquipment(SelectedWidget?.EquipmentId ?? 0)"
        LatestData="@SelectedData"
        HistoryData="@HistoryData"
        LinkConfigs="@SelectedLinkConfigs"
        EquipmentAlarms="@(ActiveAlarms.Where(a => a.EquipmentId == (SelectedWidget?.EquipmentId ?? 0)))" />

    @* ── Equipment palette drawer (edit mode) ──────────────────────────────────
       Same width and position strategy as the detail drawer.                   *@
    @{
        var mapEquip = AllEquipment
            .Where(e => !string.IsNullOrEmpty(e.MapName) && e.MapName == CurrentMap?.Name)
            .ToList();
    }
    <div style="position:absolute;right:0;top:0;width:320px;height:100%;z-index:50;
                background:#0d1b2a;border-left:1px solid #1a3a5c;overflow-y:auto;
                transform:@(_equipDrawerOpen ? "translateX(0)" : "translateX(320px)");
                transition:transform 0.25s ease;
                pointer-events:@(_equipDrawerOpen ? "auto" : "none")">

        @* Header — mirrors EquipmentDetailDrawer header style *@
        <button @onclick="@(() => _equipDrawerOpen = false)"
                style="position:absolute;top:8px;right:12px;background:none;border:none;
                       color:#888;font-size:1.2em;cursor:pointer;line-height:1;padding:2px 6px"
                title="關閉">✕</button>

        <div style="padding:16px;padding-right:36px;border-bottom:1px solid #1a3a5c">
            <div style="display:flex;align-items:center;gap:10px">
                <span style="font-size:1.4em;line-height:1">🗂️</span>
                <div>
                    <div style="color:#fff;font-weight:bold">地圖設備</div>
                    <div style="color:#888;font-size:0.8em">共 @mapEquip.Count 台 · @(Widgets.Count(w => mapEquip.Any(e => e.Id == w.EquipmentId))) 台已配置</div>
                </div>
            </div>
        </div>

        @* Equipment list — same card structure as detail drawer's data section *@
        @if (mapEquip.Count == 0)
        {
            <div style="color:#555;font-size:0.82em;padding:20px 16px">此地圖尚無設備</div>
        }
        else
        {
            <div style="padding:8px 0">
                @foreach (var eq in mapEquip)
                {
                    var placed = Widgets.Any(w => w.EquipmentId == eq.Id);
                    <div style="display:flex;align-items:center;gap:10px;padding:8px 12px;
                                border-bottom:1px solid rgba(255,255,255,.05);
                                background:@(placed ? "rgba(76,175,80,.06)" : "transparent")">
                        <div style="flex-shrink:0">
                            <EquipmentIconRenderer Equipment="@eq" />
                        </div>
                        <div style="flex:1;overflow:hidden">
                            <div style="color:#ddd;font-size:0.83em;white-space:nowrap;
                                        overflow:hidden;text-overflow:ellipsis">@eq.Name</div>
                            @if (!string.IsNullOrEmpty(eq.Tag))
                            {
                                <div style="color:#666;font-size:0.72em">@eq.Tag</div>
                            }
                        </div>
                        @if (placed)
                        {
                            <span style="font-size:0.75em;color:#4caf50;flex-shrink:0;
                                         font-weight:600">✓ 已放置</span>
                        }
                        else
                        {
                            <RadzenButton Text="＋" Size="ButtonSize.ExtraSmall"
                                          ButtonStyle="ButtonStyle.Secondary"
                                          Click="@(() => AddEquipmentToCanvas(eq))" />
                        }
                    </div>
                }
            </div>
        }
    </div>

</div>

@code {
    [Parameter, EditorRequired] public int MapId { get; set; }
    [Parameter] public bool IsEditMode { get; set; }
    [Parameter] public int? ResumeDraftId { get; set; }
    [Parameter] public EventCallback<int?> OnWorkingVersionChanged { get; set; }

    private const int VirtW = 1920;
    private const int VirtH = 1080;
    private double _scaleX = 1.0;
    private double _scaleY = 1.0;
    private bool _isFullscreen;
    private bool _equipDrawerOpen;

    private string VirtCanvasStyle =>
        $"transform:scale(" +
        $"{_scaleX.ToString("F6", System.Globalization.CultureInfo.InvariantCulture)}," +
        $"{_scaleY.ToString("F6", System.Globalization.CultureInfo.InvariantCulture)})";

    private FactoryMap? CurrentMap;
    private List<EquipmentWidget> Widgets = new();
    private List<Equipment> AllEquipment = new();
    private List<AlarmRecord> ActiveAlarms = new();

    private int?  _publishedVersionId;
    private int?  _editVersionId;
    private int   _prevMapId       = -1;
    private bool  _needsDragReinit;
    private int   _loadVersion;

    private EquipmentWidget? HoveredWidget;
    private EquipmentWidget? SelectedWidget;
    private DataResult? HoveredData;
    private DataResult? SelectedData = null;
    private IEnumerable<DataResult> HistoryData = Enumerable.Empty<DataResult>();
    private IEnumerable<EquipmentLinkConfig> SelectedLinkConfigs = Enumerable.Empty<EquipmentLinkConfig>();
    private bool DrawerOpen;

    private DotNetObjectReference<FactoryMapCanvas>? DotNetRef;
    private PeriodicTimer? _pollTimer;
    private CancellationTokenSource _cts = new();
    private bool _prevIsEditMode;

    protected override async Task OnInitializedAsync()
    {
        if (MapId <= 0) return;
        DotNetRef = DotNetObjectReference.Create(this);
        _prevMapId = MapId;
        await LoadMapDataAsync();
        _ = PollLoopAsync(_cts.Token);
    }

    protected override async Task OnParametersSetAsync()
    {
        if (MapId <= 0 || MapId == _prevMapId) return;
        _prevMapId = MapId;
        DrawerOpen = false;
        HoveredWidget = null;
        SelectedWidget = null;
        await LoadMapDataAsync();
    }

    private async Task LoadMapDataAsync()
    {
        var mapId = MapId;
        var token = ++_loadVersion;

        var maps = await MapImportSvc.GetAllAsync();
        if (_loadVersion != token) return;

        var newCurrentMap = maps.FirstOrDefault(m => m.Id == mapId);

        var published = await LayoutSvc.GetPublishedVersionAsync(mapId);
        if (_loadVersion != token) return;

        List<EquipmentWidget> newWidgets;
        int? newPublishedId;
        if (published != null)
        {
            newPublishedId = published.Id;
            var w = await EquipmentSvc.GetWidgetsByVersionAsync(published.Id);
            if (_loadVersion != token) return;
            newWidgets = w.ToList();
        }
        else
        {
            newPublishedId = null;
            newWidgets = new();
        }

        var allEq = await EquipmentSvc.GetAllEquipmentAsync();
        if (_loadVersion != token) return;

        var alarms = await AlarmSvc.GetActiveAlarmsAsync();
        if (_loadVersion != token) return;

        CurrentMap          = newCurrentMap;
        _publishedVersionId = newPublishedId;
        Widgets             = newWidgets;
        AllEquipment        = allEq.ToList();
        ActiveAlarms        = alarms.ToList();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                await JS.InvokeVoidAsync("kanbanCanvas.observeResize", "map-canvas", DotNetRef);
                await JS.InvokeVoidAsync("kanbanCanvas.observeFullscreen", DotNetRef);
            }
            catch (JSException) { }
        }

        if (IsEditMode && !_prevIsEditMode)
        {
            await BeginEditSessionAsync();
            _needsDragReinit = false;
            try { await JS.InvokeVoidAsync("kanbanDrag.init", "map-canvas", DotNetRef); }
            catch (JSException) { }
        }
        else if (IsEditMode && _needsDragReinit)
        {
            _needsDragReinit = false;
            try { await JS.InvokeVoidAsync("kanbanDrag.init", "map-canvas", DotNetRef); }
            catch (JSException) { }
        }
        else if (!IsEditMode && _prevIsEditMode)
        {
            await EndEditSessionAsync();
            try { await JS.InvokeVoidAsync("kanbanDrag.destroy"); }
            catch (JSException) { }
        }
        _prevIsEditMode = IsEditMode;
    }

    [JSInvokable]
    public Task OnCanvasResized(double w, double h)
    {
        if (w <= 0 || h <= 0) return Task.CompletedTask;
        _scaleX = w / VirtW;
        _scaleY = h / VirtH;
        return InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public Task OnFullscreenChanged(bool isFs)
    {
        _isFullscreen = isFs;
        return InvokeAsync(StateHasChanged);
    }

    private async Task ToggleFullscreen()
    {
        try { await JS.InvokeVoidAsync("kanbanCanvas.toggleFullscreen", "kanban-fs-wrapper"); }
        catch (JSException) { }
    }

    private async Task BeginEditSessionAsync()
    {
        if (MapId <= 0) return;
        DrawerOpen       = false;   // detail drawer and equipment drawer don't coexist
        SelectedWidget   = null;
        _equipDrawerOpen = true;
        try
        {
            if (ResumeDraftId.HasValue)
            {
                _editVersionId = ResumeDraftId.Value;
                Widgets = (await EquipmentSvc.GetWidgetsByVersionAsync(ResumeDraftId.Value)).ToList();
            }
            else
            {
                var draft = await LayoutSvc.SaveDraftAsync(MapId, "{}", "系統");
                _editVersionId = draft.Id;

                if (_publishedVersionId.HasValue)
                {
                    var published = await EquipmentSvc.GetWidgetsByVersionAsync(_publishedVersionId.Value);
                    foreach (var w in published)
                    {
                        await EquipmentSvc.SaveWidgetAsync(new EquipmentWidget
                        {
                            EquipmentId     = w.EquipmentId,
                            LayoutVersionId = draft.Id,
                            PositionX       = w.PositionX,
                            PositionY       = w.PositionY,
                            Width           = w.Width,
                            Height          = w.Height,
                        });
                    }
                    Widgets = (await EquipmentSvc.GetWidgetsByVersionAsync(draft.Id)).ToList();
                }
            }

            await OnWorkingVersionChanged.InvokeAsync(_editVersionId);
            await InvokeAsync(StateHasChanged);
        }
        catch { }
    }

    private async Task EndEditSessionAsync()
    {
        _editVersionId   = null;
        _equipDrawerOpen = false;
        await OnWorkingVersionChanged.InvokeAsync(null);

        var published = await LayoutSvc.GetPublishedVersionAsync(MapId);
        if (published != null)
        {
            _publishedVersionId = published.Id;
            Widgets = (await EquipmentSvc.GetWidgetsByVersionAsync(published.Id)).ToList();
        }
        else
        {
            _publishedVersionId = null;
            Widgets = new();
        }
        await InvokeAsync(StateHasChanged);
    }

    private async Task PollLoopAsync(CancellationToken ct)
    {
        _pollTimer = new PeriodicTimer(TimeSpan.FromSeconds(ModuleOpts.Value.MapPollIntervalSeconds));
        try
        {
            while (await _pollTimer.WaitForNextTickAsync(ct))
            {
                try
                {
                    ActiveAlarms = (await AlarmSvc.GetActiveAlarmsAsync()).ToList();
                    await InvokeAsync(StateHasChanged);
                }
                catch { }
            }
        }
        catch (OperationCanceledException) { }
    }

    [JSInvokable]
    public async Task OnEquipmentMoved(string equipmentIdStr, int x, int y)
    {
        if (!int.TryParse(equipmentIdStr, out var equipmentId)) return;
        var widget = Widgets.FirstOrDefault(w => w.EquipmentId == equipmentId);
        if (widget == null) return;
        widget.PositionX = x;
        widget.PositionY = y;
        try { await EquipmentSvc.SaveWidgetAsync(widget); }
        catch (Exception ex) { _ = ex; }
        await InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public async Task OnEquipmentsBatchMoved(List<EquipmentMoveItem> moves)
    {
        foreach (var m in moves)
        {
            if (!int.TryParse(m.Id, out var eid)) continue;
            var widget = Widgets.FirstOrDefault(w => w.EquipmentId == eid);
            if (widget == null) continue;
            widget.PositionX = m.X;
            widget.PositionY = m.Y;
            try { await EquipmentSvc.SaveWidgetAsync(widget); }
            catch (Exception ex) { _ = ex; }
        }
        await InvokeAsync(StateHasChanged);
    }

    public class EquipmentMoveItem
    {
        public string Id { get; set; } = "";
        public int X { get; set; }
        public int Y { get; set; }
    }

    private async Task HandleWidgetClick(EquipmentWidget widget)
    {
        // In edit mode clicks are for drag placement only — never open the detail drawer.
        if (IsEditMode) return;

        if (DrawerOpen && SelectedWidget?.EquipmentId == widget.EquipmentId)
        {
            DrawerOpen = false;
            return;
        }
        SelectedWidget = widget;
        try
        {
            SelectedLinkConfigs = await EquipmentSvc.GetLinkConfigsAsync(widget.EquipmentId);
        }
        catch
        {
            SelectedLinkConfigs = Enumerable.Empty<EquipmentLinkConfig>();
        }
        DrawerOpen = true;
    }

    private async Task HandleWidgetHover(EquipmentWidget widget)
    {
        HoveredWidget = widget;
        await InvokeAsync(StateHasChanged);
    }

    private void HandleHoverEnd()
    {
        HoveredWidget = null;
        HoveredData   = null;
    }

    private async Task AddEquipmentToCanvas(Equipment eq)
    {
        var versionId = _editVersionId;
        if (versionId == null)
        {
            if (_publishedVersionId == null)
            {
                try
                {
                    var d = await LayoutSvc.SaveDraftAsync(MapId, "{}", "系統");
                    var p = await LayoutSvc.PublishAsync(d.Id);
                    _publishedVersionId = p.Id;
                }
                catch { return; }
            }
            versionId = _publishedVersionId;
        }

        var widget = new EquipmentWidget
        {
            EquipmentId     = eq.Id,
            LayoutVersionId = versionId.Value,
            PositionX       = 120,
            PositionY       = 120,
            Width           = 80,
            Height          = 100,
        };
        try
        {
            await EquipmentSvc.SaveWidgetAsync(widget);
            var loadVer = _editVersionId ?? _publishedVersionId;
            if (loadVer.HasValue)
                Widgets = (await EquipmentSvc.GetWidgetsByVersionAsync(loadVer.Value)).ToList();
            _needsDragReinit = true;
            await InvokeAsync(StateHasChanged);
        }
        catch { }
    }

    private Equipment? GetEquipment(int equipmentId)
        => AllEquipment.FirstOrDefault(e => e.Id == equipmentId);

    private AlarmLevel? GetActiveAlarm(int equipmentId)
    {
        var alarm = ActiveAlarms
            .Where(a => a.EquipmentId == equipmentId)
            .OrderByDescending(a => a.Level)
            .FirstOrDefault();
        return alarm?.Level;
    }

    private bool GetIsRunning(int equipmentId)
        => !ActiveAlarms.Any(a => a.EquipmentId == equipmentId);

    public async ValueTask DisposeAsync()
    {
        _cts.Cancel();
        _cts.Dispose();
        _pollTimer?.Dispose();
        try { await JS.InvokeVoidAsync("kanbanCanvas.unobserveResize"); } catch { }
        DotNetRef?.Dispose();
        if (IsEditMode)
        {
            try { await JS.InvokeVoidAsync("kanbanDrag.destroy"); }
            catch (JSDisconnectedException) { }
        }
    }
}
