@if (Map != null)
{
    @switch (Map.FormatType)
    {
        case MapFormatType.Png:
        case MapFormatType.Jpg:
        case MapFormatType.Svg:
        case MapFormatType.Dxf:
            @* W-3/W-4 fix: render all image-based maps via <img>, not MarkupString.
               Loading SVG/DXF through <img> sandboxes embedded scripts (no XSS).
               It also avoids the broken server-side File.Exists(relative-path) path
               resolution — the browser fetches the URL directly. *@
            <img src="@Map.FilePath" alt="@Map.Name" class="kanban-map-layer"
                 style="position:absolute;inset:0;width:100%;height:100%;object-fit:fill;opacity:0.65;pointer-events:none;" />
            break;

        case MapFormatType.JsonCoord:
        case MapFormatType.XmlCoord:
            @* Coord-based maps have no background image — equipment positions come from data *@
            break;
    }
}

@code {
    [Parameter] public FactoryMap? Map { get; set; }
}
