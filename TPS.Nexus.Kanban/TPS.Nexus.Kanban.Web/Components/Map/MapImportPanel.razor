@inject IMapImportService MapImportSvc
@inject IOptions<KanbanModuleOptions> ModuleOpts

<RadzenCard Style="padding:16px">
    <RadzenText TextStyle="TextStyle.H6">匯入廠區地圖</RadzenText>

    <RadzenFormField Text="地圖格式" Style="width:100%;margin-top:8px">
        <RadzenDropDown @bind-Value="SelectedFormat" Data="@FormatOptions"
                        TextProperty="Label" ValueProperty="Value" />
    </RadzenFormField>

    <div style="margin-top:12px">
        <InputFile OnChange="@OnFileSelected"
                   accept=".png,.jpg,.jpeg,.svg,.dxf,.json,.xml"
                   style="color:#aaa;width:100%" />
    </div>

    @if (!string.IsNullOrEmpty(_previewUrl))
    {
        <div style="margin-top:10px;padding:8px;background:rgba(255,255,255,.04);
                    border-radius:4px;border:1px solid rgba(255,255,255,.12);text-align:center">
            <img src="@_previewUrl" alt="地圖預覽"
                 style="max-width:100%;max-height:200px;object-fit:contain" />
        </div>
    }

    <RadzenButton Text="上傳並匯入" ButtonStyle="ButtonStyle.Primary"
                  Style="margin-top:12px;width:100%"
                  Disabled="@(_selectedFileBytes == null)"
                  Click="@DoImport" />

    @if (!string.IsNullOrEmpty(StatusMessage))
    {
        <div style="margin-top:8px;color:@(_isError ? "#f44336" : "#4caf50");font-size:0.85em">
            @StatusMessage
        </div>
    }
</RadzenCard>

@code {
    [Parameter] public EventCallback<FactoryMap> OnImported { get; set; }

    private byte[]? _selectedFileBytes;
    private string  _selectedFileName = string.Empty;
    private string  _previewUrl       = string.Empty;
    private MapFormatType SelectedFormat = MapFormatType.Png;
    private string StatusMessage = string.Empty;
    private bool   _isError;

    private record FormatOption(string Label, MapFormatType Value);
    private static readonly List<FormatOption> FormatOptions = new()
    {
        new("PNG 圖片",      MapFormatType.Png),
        new("JPG 圖片",      MapFormatType.Jpg),
        new("SVG 向量圖",    MapFormatType.Svg),
        new("DXF 工程圖",    MapFormatType.Dxf),
        new("JSON 座標定義", MapFormatType.JsonCoord),
        new("XML 座標定義",  MapFormatType.XmlCoord),
    };

    private async Task OnFileSelected(InputFileChangeEventArgs args)
    {
        _selectedFileBytes = null;
        _selectedFileName  = string.Empty;
        _previewUrl        = string.Empty;
        StatusMessage      = string.Empty;
        try
        {
            var file = args.File;
            _selectedFileName = file.Name;
            // Read immediately — IBrowserFile JS ref becomes invalid after re-render
            await using var src = file.OpenReadStream(maxAllowedSize: ModuleOpts.Value.MapUploadMaxBytes);
            using var ms = new MemoryStream();
            await src.CopyToAsync(ms);
            _selectedFileBytes = ms.ToArray();

            if (SelectedFormat is MapFormatType.Png or MapFormatType.Jpg or MapFormatType.Svg)
            {
                var mime = SelectedFormat switch
                {
                    MapFormatType.Png => "image/png",
                    MapFormatType.Jpg => "image/jpeg",
                    MapFormatType.Svg => "image/svg+xml",
                    _                 => "image/png",
                };
                _previewUrl = $"data:{mime};base64,{Convert.ToBase64String(_selectedFileBytes)}";
            }
        }
        catch (Exception ex)
        {
            _isError      = true;
            StatusMessage = $"❌ 讀取檔案失敗：{ex.Message}";
        }
    }

    private async Task DoImport()
    {
        if (_selectedFileBytes == null) return;
        _isError      = false;
        StatusMessage = "匯入中...";

        try
        {
            using var stream = new MemoryStream(_selectedFileBytes);
            var map = await MapImportSvc.ImportAsync(stream, _selectedFileName, SelectedFormat);
            StatusMessage      = $"✅ 已匯入：{map.Name}";
            _selectedFileBytes = null;
            _previewUrl        = string.Empty;
            await OnImported.InvokeAsync(map);
        }
        catch (Exception ex)
        {
            _isError      = true;
            StatusMessage = $"❌ 匯入失敗：{ex.Message}";
        }
    }
}
