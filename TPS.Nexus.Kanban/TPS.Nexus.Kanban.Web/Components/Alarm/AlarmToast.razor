@inject NotificationService NotificationSvc
@inject IOptions<KanbanModuleOptions> ModuleOpts
@implements IDisposable

<RadzenNotification />

@code {
    [Parameter] public Microsoft.AspNetCore.SignalR.Client.HubConnection? HubConnection { get; set; }

    private Microsoft.AspNetCore.SignalR.Client.HubConnection? _registeredHub;

    protected override void OnParametersSet()
    {
        if (ReferenceEquals(_registeredHub, HubConnection)) return;

        _registeredHub?.Remove(KanbanRoutes.ReceiveAlarmEvent);
        _registeredHub = HubConnection;

        HubConnection?.On<int, string, string>(KanbanRoutes.ReceiveAlarmEvent, (equipmentId, level, message) =>
        {
            var severity = Enum.TryParse<AlarmLevel>(level, out var parsedLevel)
                ? parsedLevel switch
                {
                    AlarmLevel.Critical => NotificationSeverity.Error,
                    AlarmLevel.Warning  => NotificationSeverity.Warning,
                    _                   => NotificationSeverity.Info
                }
                : NotificationSeverity.Info;
            InvokeAsync(() => NotificationSvc.Notify(severity, $"警報 [{level}]", message,
                duration: ModuleOpts.Value.AlarmToastDurationMs));
        });
    }

    public void Dispose()
    {
        _registeredHub?.Remove(KanbanRoutes.ReceiveAlarmEvent);
    }
}
