@inject NotificationService NotificationSvc
@implements IDisposable

<RadzenNotification />

@code {
    [Parameter] public Microsoft.AspNetCore.SignalR.Client.HubConnection? HubConnection { get; set; }

    private Microsoft.AspNetCore.SignalR.Client.HubConnection? _registeredHub;

    protected override void OnParametersSet()
    {
        if (ReferenceEquals(_registeredHub, HubConnection)) return;

        _registeredHub?.Remove("ReceiveAlarm");
        _registeredHub = HubConnection;

        HubConnection?.On<int, string, string>("ReceiveAlarm", (equipmentId, level, message) =>
        {
            var severity = level switch
            {
                "Critical" => NotificationSeverity.Error,
                "Warning"  => NotificationSeverity.Warning,
                _ => NotificationSeverity.Info
            };
            InvokeAsync(() => NotificationSvc.Notify(severity, $"警報 [{level}]", message, duration: 5000));
        });
    }

    public void Dispose()
    {
        _registeredHub?.Remove("ReceiveAlarm");
    }
}
