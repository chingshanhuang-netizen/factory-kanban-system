@inject NotificationService NotifySvc
@inject DialogService DialogSvc

<RadzenStack Gap="16px" Style="padding:4px;min-width:360px">

    @if (ExistingDataTypes.Count > 0)
    {
        <div>
            <div style="color:#aaa;font-size:0.82em;margin-bottom:8px">現有資料類型</div>
            <div style="display:flex;flex-wrap:wrap;gap:6px">
                @foreach (var type in ExistingDataTypes)
                {
                    <span style="padding:4px 12px;background:rgba(255,255,255,.08);
                                 border-radius:12px;font-size:0.85em;color:#ddd;
                                 white-space:nowrap">@type</span>
                }
            </div>
        </div>
        <hr style="border:none;border-top:1px solid rgba(255,255,255,.1);margin:0" />
    }

    <RadzenFormField Text="新資料類型名稱 *" Variant="Variant.Outlined">
        <RadzenTextBox @bind-Value="_name"
                       Placeholder="例如：溫度感測"
                       Style="width:100%"
                       @onkeydown="@OnKeyDown" />
    </RadzenFormField>

    <div style="display:flex;justify-content:flex-end;gap:8px">
        <RadzenButton Text="取消" ButtonStyle="ButtonStyle.Light" Click="@Cancel" />
        <RadzenButton Text="新增" ButtonStyle="ButtonStyle.Primary" Click="@Save" />
    </div>

</RadzenStack>

@code {
    [Parameter] public List<string> ExistingDataTypes { get; set; } = new();

    private string _name = string.Empty;

    private void Cancel() => DialogSvc.Close(null);

    private void Save()
    {
        var trimmed = _name.Trim();
        if (string.IsNullOrEmpty(trimmed))
        {
            NotifySvc.Notify(NotificationSeverity.Warning, "請輸入資料類型名稱");
            return;
        }
        if (ExistingDataTypes.Contains(trimmed, StringComparer.OrdinalIgnoreCase))
        {
            NotifySvc.Notify(NotificationSeverity.Warning, "資料類型已存在", $"「{trimmed}」已在清單中");
            return;
        }
        DialogSvc.Close(trimmed);
    }

    private void OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") Save();
    }
}
