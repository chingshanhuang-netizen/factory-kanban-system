@inject IFunctionPermissionService PermSvc

<div id="kanban-map-toolbar" style="display:flex;align-items:center;gap:8px;background:#0d1b2a;border-bottom:1px solid #1a3a5c;padding:4px 12px">
    @if (AllMaps.Count > 1)
    {
        <select @onchange="@(e => OnMapSelected.InvokeAsync(int.Parse(e.Value?.ToString() ?? "0")))"
                style="background:#1a3a5c;color:#fff;border:1px solid #2a5a8c;border-radius:4px;
                       padding:3px 10px;font-size:0.85em;cursor:pointer;outline:none;
                       min-width:140px;max-width:220px">
            @foreach (var m in AllMaps)
            {
                if (m.Id == CurrentMapId)
                {
                    <option value="@m.Id" selected style="background:#0d1b2a;color:#fff">🗺️ @m.Name</option>
                }
                else
                {
                    <option value="@m.Id" style="background:#0d1b2a;color:#fff">🗺️ @m.Name</option>
                }
            }
        </select>
    }
    else
    {
        <span style="color:#aaa;font-size:0.85em">
            🗺️ <strong style="color:#fff">@MapName</strong>
        </span>
    }

    @if (CanEdit)
    {
        <button @onclick="ToggleEditMode"
                style="@(IsEditMode ? SuccessBtn : SecondaryBtn)">
            @(IsEditMode ? "✅ 完成編輯" : "✏️ 編輯")
        </button>
    }

    @if (IsEditMode)
    {
        <button @onclick="SaveDraft" style="@WarningBtn">💾 存草稿</button>

        @if (CanPublish)
        {
            <button @onclick="Publish" style="@PrimaryBtn">🚀 發布</button>
        }
    }

    <button @onclick="ShowVersionPanel" style="@DefaultBtn">📋 版本</button>
</div>

@code {
    [Parameter] public string MapName { get; set; } = string.Empty;
    [Parameter] public List<FactoryMap> AllMaps { get; set; } = new();
    [Parameter] public int CurrentMapId { get; set; }
    [Parameter] public EventCallback<int> OnMapSelected { get; set; }
    [Parameter] public LayoutVersion? PublishedVersion { get; set; }
    [Parameter] public bool IsEditMode { get; set; }
    [Parameter] public EventCallback<bool> IsEditModeChanged { get; set; }
    [Parameter] public EventCallback OnSaveDraft { get; set; }
    [Parameter] public EventCallback OnPublish { get; set; }
    [Parameter] public EventCallback OnShowVersions { get; set; }

    private bool CanEdit;
    private bool CanPublish;

    private const string Base =
        "color:#fff;border-radius:4px;padding:3px 10px;cursor:pointer;" +
        "font-size:0.84em;line-height:1.6;transition:background 0.15s;border:1px solid;";

    private const string DefaultBtn   = Base + "background:rgba(255,255,255,.10);border-color:rgba(255,255,255,.25);";
    private const string SecondaryBtn = Base + "background:rgba(100,130,160,.25);border-color:rgba(100,130,160,.55);";
    private const string SuccessBtn   = Base + "background:rgba(76,175,80,.30);border-color:rgba(76,175,80,.70);";
    private const string WarningBtn   = Base + "background:rgba(255,152,0,.25);border-color:rgba(255,152,0,.65);";
    private const string PrimaryBtn   = Base + "background:rgba(33,150,243,.30);border-color:rgba(33,150,243,.70);";

    protected override async Task OnInitializedAsync()
    {
        CanEdit    = await PermSvc.HasPermissionAsync(KanbanPermissions.Edit);
        CanPublish = await PermSvc.HasPermissionAsync(KanbanPermissions.Publish);
    }

    private async Task ToggleEditMode()
    {
        IsEditMode = !IsEditMode;
        await IsEditModeChanged.InvokeAsync(IsEditMode);
    }

    private async Task SaveDraft()       => await OnSaveDraft.InvokeAsync();
    private async Task Publish()         => await OnPublish.InvokeAsync();
    private async Task ShowVersionPanel() => await OnShowVersions.InvokeAsync();
}
