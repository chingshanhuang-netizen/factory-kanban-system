@inject IDataSourceService DataSvc
@inject IEquipmentService EquipmentSvc
@inject IOptions<KanbanModuleOptions> ModuleOpts

<div style="position:absolute;right:0;top:0;width:320px;height:100%;z-index:50;
            background:#0d1b2a;border-left:1px solid #1a3a5c;overflow-y:auto;
            transform:@(IsOpen ? "translateX(0)" : "translateX(420px)");
            transition:transform 0.25s ease;
            pointer-events:@(IsOpen ? "auto" : "none")">
    <button @onclick="@(() => IsOpenChanged.InvokeAsync(false))"
            style="position:absolute;top:8px;right:12px;background:none;border:none;
                   color:#888;font-size:1.2em;cursor:pointer;line-height:1;padding:2px 6px"
            title="關閉">✕</button>
    @if (EquipmentData != null)
    {
        <div style="padding:16px;padding-right:36px;border-bottom:1px solid #1a3a5c">
            <div style="display:flex;align-items:center;gap:10px">
                <EquipmentIconRenderer Equipment="@EquipmentData" />
                <div>
                    <div style="color:#fff;font-weight:bold">@EquipmentData.Name</div>
                    @if (!string.IsNullOrEmpty(EquipmentData.Tag))
                    {
                        <div style="color:#888;font-size:0.8em">@EquipmentData.Tag</div>
                    }
                </div>
            </div>
        </div>

        <RadzenTabs Style="height:calc(100vh - 80px);overflow:auto">
            <Tabs>
                <RadzenTabsItem Text="當前數值">
                    @if (EquipmentAlarms.Any())
                    {
                        <div style="margin:8px;padding:10px;background:rgba(127,0,0,.3);
                                    border-radius:4px;border-left:3px solid #f44336">
                            <div style="color:#f44336;font-weight:600;font-size:0.85em;margin-bottom:6px">
                                ⚠ 告警（@EquipmentAlarms.Count() 筆）
                            </div>
                            @foreach (var alarm in EquipmentAlarms.OrderByDescending(a => (int)a.Level))
                            {
                                <div style="font-size:0.82em;color:#ffb3b3;padding:2px 0">
                                    [@alarm.Level] @alarm.Message
                                    <span style="color:#888;margin-left:4px">
                                        @alarm.TriggeredAt.ToLocalTime().ToString("MM/dd HH:mm")
                                    </span>
                                </div>
                            }
                        </div>
                    }

                    @if (LatestData?.Fields.Any() == true)
                    {
                        <div style="margin:6px 8px 4px;display:flex;justify-content:flex-end">
                            <input type="text" @bind="_fieldSearch" @bind:event="oninput"
                                   placeholder="🔍 搜尋參數..."
                                   style="background:rgba(255,255,255,.07);border:1px solid #2a4a6c;
                                          color:#c8d8e8;border-radius:4px;padding:3px 8px;
                                          font-size:0.82em;outline:none;width:150px" />
                        </div>
                        <RadzenDataGrid Data="@FilteredFields" TItem="KeyValuePair<string,object?>"
                                        Style="font-size:0.85em; height: calc(100vh - 360px)"
                                        AllowSorting="true" AllowFiltering="true" FilterMode="FilterMode.Simple"
                                        AllowPaging="true" PageSize="@_fieldPageSize"
                                        PageSizeOptions="@(new int[]{10,20,50,100})"
                                        Page="@((args) => _fieldPage = args.PageIndex)"
                                        PageSizeChanged="@((size) => { _fieldPageSize = size; _fieldPage = 0; })"
                                        ShowPagingSummary="true" PagingSummaryFormat="@FieldPageSummary"
                                        class="kanban-light-grid">
                            <Columns>
                                <RadzenDataGridColumn TItem="KeyValuePair<string,object?>"
                                                      Property="Key" Title="參數" Width="120px" />
                                <RadzenDataGridColumn TItem="KeyValuePair<string,object?>"
                                                      Property="Value" Title="數值" />
                            </Columns>
                        </RadzenDataGrid>
                    }

                    @if (HistoryData.Any())
                    {
                        <RadzenChart Style="height:200px;margin-top:16px">
                            <RadzenLineSeries Data="@ChartPoints" CategoryProperty="Label" ValueProperty="Value"
                                             Stroke="#2196f3" StrokeWidth="2">
                            </RadzenLineSeries>
                        </RadzenChart>
                    }
                </RadzenTabsItem>

                @foreach (var linkConfig in LinkConfigs.OrderBy(l => l.DisplayOrder))
                {
                    <RadzenTabsItem Text="@linkConfig.TabLabel">
                        @switch (linkConfig.LinkType)
                        {
                            case LinkType.WorkOrder:
                            case LinkType.AlarmHistory:
                                @if (TabData.TryGetValue(linkConfig.Id, out var rows) && rows.Any())
                                {
                                    <div style="margin:4px 8px;display:flex;justify-content:flex-end">
                                        <input type="text"
                                               value="@TabSearch(linkConfig.Id)"
                                               @oninput="@(e => SetTabSearch(linkConfig.Id, e.Value?.ToString() ?? ""))"
                                               placeholder="🔍 搜尋..."
                                               style="background:rgba(255,255,255,.07);border:1px solid #2a4a6c;
                                                      color:#c8d8e8;border-radius:4px;padding:3px 8px;
                                                      font-size:0.82em;outline:none;width:140px" />
                                    </div>
                                    <RadzenDataGrid Data="@FilteredTabRows(linkConfig.Id, rows)" TItem="DataResult"
                                                    Style="font-size:0.82em; height: calc(100vh - 360px)"
                                                    AllowSorting="true" AllowFiltering="true" FilterMode="FilterMode.Simple"
                                                    AllowPaging="true" PageSize="@TabPageSize(linkConfig.Id)"
                                                    PageSizeOptions="@(new int[]{10,20,50,100})"
                                                    Page="@((args) => _tabPage[linkConfig.Id] = args.PageIndex)"
                                                    PageSizeChanged="@((size) => { _tabPageSize[linkConfig.Id] = size; _tabPage[linkConfig.Id] = 0; })"
                                                    ShowPagingSummary="true" PagingSummaryFormat="@TabPageSummary(linkConfig.Id, FilteredTabRows(linkConfig.Id, rows).Count())"
                                                    class="kanban-light-grid">
                                        <Columns>
                                            @foreach (var key in rows.First().Fields.Keys.Take(ModuleOpts.Value.TabDataColumnsMaxCount))
                                            {
                                                <RadzenDataGridColumn TItem="DataResult" Title="@key"
                                                    Property="@($"Fields[\"{key}\"]")" />
                                            }
                                        </Columns>
                                    </RadzenDataGrid>
                                }
                                else
                                {
                                    <div style="color:#555;padding:16px">暫無資料</div>
                                }
                                break;

                            case LinkType.Document:
                                @if (SanitizeUrl(linkConfig.UrlTemplate?.Replace("{equipmentId}", EquipmentData.Id.ToString())) is { } docUrl)
                                {
                                    <a href="@docUrl" target="_blank" style="color:#2196f3">@linkConfig.TabLabel 文件連結</a>
                                }
                                else if (!string.IsNullOrEmpty(linkConfig.UrlTemplate))
                                {
                                    <div style="color:#f44336;font-size:0.8em">⚠ 不支援的 URL 格式（需以 https:// 或 / 開頭）</div>
                                }
                                break;

                            case LinkType.CustomUrl:
                                @if (SanitizeUrl(linkConfig.UrlTemplate?.Replace("{equipmentId}", EquipmentData.Id.ToString())) is { } iframeUrl)
                                {
                                    <iframe src="@iframeUrl" style="width:100%;height:400px;border:none;"></iframe>
                                }
                                else if (!string.IsNullOrEmpty(linkConfig.UrlTemplate))
                                {
                                    <div style="color:#f44336;font-size:0.8em">⚠ 不支援的 URL 格式（需以 https:// 或 / 開頭）</div>
                                }
                                break;
                        }
                    </RadzenTabsItem>
                }
            </Tabs>
        </RadzenTabs>
    }
</div>

@code {
    [Parameter] public bool IsOpen { get; set; }
    [Parameter] public EventCallback<bool> IsOpenChanged { get; set; }
    [Parameter] public EquipmentWidget? Widget { get; set; }
    [Parameter] public Equipment? EquipmentData { get; set; }
    [Parameter] public DataResult? LatestData { get; set; }
    [Parameter] public IEnumerable<DataResult> HistoryData { get; set; } = Enumerable.Empty<DataResult>();
    [Parameter] public IEnumerable<EquipmentLinkConfig> LinkConfigs { get; set; } = Enumerable.Empty<EquipmentLinkConfig>();
    [Parameter] public IEnumerable<AlarmRecord> EquipmentAlarms { get; set; } = Enumerable.Empty<AlarmRecord>();

    private Dictionary<int, List<DataResult>> TabData = new();
    private List<TrendPoint> ChartPoints = new();
    private string _fieldSearch   = "";
    private int    _fieldPage     = 0;
    private int    _fieldPageSize = 10;
    private Dictionary<int, string> _tabSearch    = new();
    private Dictionary<int, int>    _tabPage      = new();
    private Dictionary<int, int>    _tabPageSize  = new();

    private string FieldPageSummary
    {
        get
        {
            var total = FilteredFields.Count();
            var pages = total == 0 ? 1 : (int)Math.Ceiling((double)total / _fieldPageSize);
            return $"Page {_fieldPage + 1} of {pages} ({total} Items)";
        }
    }

    private string TabPageSummary(int id, int rowCount)
    {
        var size  = _tabPageSize.TryGetValue(id, out var s) ? s : 10;
        var page0 = _tabPage.TryGetValue(id, out var p) ? p : 0;
        var pages = rowCount == 0 ? 1 : (int)Math.Ceiling((double)rowCount / size);
        return $"Page {page0 + 1} of {pages} ({rowCount} Items)";
    }

    private int TabPageSize(int id) => _tabPageSize.TryGetValue(id, out var s) ? s : 10;

    public record TrendPoint(string Label, double Value);

    private IEnumerable<KeyValuePair<string, object?>> FilteredFields =>
        LatestData?.Fields is null
            ? Enumerable.Empty<KeyValuePair<string, object?>>()
            : string.IsNullOrWhiteSpace(_fieldSearch)
                ? LatestData.Fields
                : LatestData.Fields.Where(kv =>
                    kv.Key.Contains(_fieldSearch, StringComparison.OrdinalIgnoreCase));

    private string TabSearch(int id) =>
        _tabSearch.TryGetValue(id, out var s) ? s : "";

    private void SetTabSearch(int id, string val) =>
        _tabSearch[id] = val;

    private IEnumerable<DataResult> FilteredTabRows(int id, List<DataResult> rows)
    {
        var term = TabSearch(id);
        if (string.IsNullOrWhiteSpace(term)) return rows;
        return rows.Where(r => r.Fields.Values.Any(v =>
            v?.ToString()?.Contains(term, StringComparison.OrdinalIgnoreCase) == true));
    }

    // W-5: allow only safe URL schemes — javascript: and data: URIs must be rejected
    private static string? SanitizeUrl(string? url) =>
        url != null &&
        (url.StartsWith("https://", StringComparison.OrdinalIgnoreCase) ||
         url.StartsWith("http://",  StringComparison.OrdinalIgnoreCase) ||
         url.StartsWith("/"))
            ? url : null;

    protected override async Task OnParametersSetAsync()
    {
        if (!IsOpen || EquipmentData == null) return;

        _fieldSearch = "";
        _fieldPage   = 0;
        _tabSearch.Clear();
        _tabPage.Clear();
        _tabPageSize.Clear();
        TabData.Clear();
        var allConfigs = (await EquipmentSvc.GetAllDataSourceConfigsAsync())
                             .ToDictionary(c => c.Id);
        var from = DateTime.UtcNow.AddHours(-ModuleOpts.Value.TabDataWindowHours);
        var to   = DateTime.UtcNow;

        foreach (var lc in LinkConfigs.Where(l =>
            l.DataSourceConfigId.HasValue &&
            (l.LinkType == LinkType.WorkOrder || l.LinkType == LinkType.AlarmHistory)))
        {
            if (!allConfigs.TryGetValue(lc.DataSourceConfigId!.Value, out var config))
                continue;

            try
            {
                var rows = await DataSvc.FetchHistoryAsync(config, from, to);
                TabData[lc.Id] = rows.ToList();
            }
            catch
            {
                TabData[lc.Id] = new List<DataResult>();
            }
        }

        ChartPoints.Clear();
        int i = 0;
        foreach (var row in HistoryData.TakeLast(ModuleOpts.Value.HistoryChartMaxRows))
        {
            var v = row.Fields.Values.FirstOrDefault();
            if (v != null && double.TryParse(v.ToString(), out var val))
                ChartPoints.Add(new TrendPoint((i++).ToString(), val));
        }
    }
}
