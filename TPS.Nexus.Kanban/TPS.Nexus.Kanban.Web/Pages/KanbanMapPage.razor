@page "/kanban/{MapId:int}"
@inject IMapImportService MapImportSvc
@inject ILayoutService LayoutSvc
@inject IAlarmService AlarmSvc
@inject IFunctionPermissionService PermSvc
@inject NotificationService NotifySvc
@inject DialogService DialogSvc
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject UserPrefsService UserPrefs
@implements IAsyncDisposable

<PageTitle>工廠看板 — @(CurrentMap?.Name ?? "載入中")</PageTitle>

@if (!CanView)
{
    <div style="padding:40px;text-align:center;color:#f44336">無查看權限（需要 @KanbanPermissions.View）</div>
    return;
}

@if (CurrentMap == null)
{
    <div style="padding:40px;text-align:center;color:#888">地圖載入中...</div>
    return;
}

<MapEditorToolbar
    MapName="@CurrentMap.Name"
    AllMaps="@AllMaps"
    CurrentMapId="@MapId"
    OnMapSelected="@((id) => Navigation.NavigateTo($"/kanban/{id}"))"
    PublishedVersion="@PublishedVersion"
    IsEditMode="@IsEditMode"
    IsEditModeChanged="@HandleEditModeChanged"
    OnSaveDraft="@HandleSaveDraft"
    OnPublish="@HandlePublish"
    OnShowVersions="@HandleShowVersions" />

<div style="position:relative;height:calc(100vh - 102px)">
    <FactoryMapCanvas MapId="@MapId" IsEditMode="@IsEditMode"
                      ResumeDraftId="@_resumeDraftId"
                      OnWorkingVersionChanged="@((id) => DraftId = id)"
                      CarouselVisible="@(CurrentMap?.CarouselEnabled == true && AllMaps.Any(m => m.CarouselEnabled))"
                      CarouselPaused="@_carouselPaused"
                      CarouselRemainingSeconds="@_carouselRemainingSeconds"
                      OnCarouselTogglePause="@ToggleCarouselPause" />

    @if (ShowVersions)
    {
        <div style="position:absolute;right:0;top:0;width:320px;height:100%;
                    border-left:1px solid #1a3a5c;overflow-y:auto;
                    background:#0d1b2a;z-index:300">
            <LayoutVersionPanel MapId="@MapId" OnRolledBack="@HandleRollback" />
        </div>
    }
</div>

<AlarmToast HubConnection="@HubConn" />

@code {
    [Parameter] public int MapId { get; set; }

    private FactoryMap? CurrentMap;
    private List<FactoryMap> AllMaps = new();
    private LayoutVersion? PublishedVersion;
    private List<AlarmRecord> ActiveAlarms = new();
    private bool CanView;
    private bool IsEditMode;
    private bool ShowVersions;
    private int? DraftId;
    private HubConnection? HubConn;
    private int  _prevMapId = -1;
    private CancellationTokenSource? _carouselCts;
    private bool _carouselPaused;
    private int  _carouselRemainingSeconds;
    private int? _resumeDraftId;

    protected override async Task OnInitializedAsync()
    {
        CanView = await PermSvc.HasPermissionAsync(KanbanPermissions.View);
        if (!CanView) return;

        // Load persisted prefs; if the user's last-used map differs from the URL param, redirect.
        await UserPrefs.EnsureLoadedAsync(JS);
        if (UserPrefs.SelectedMapId.HasValue && UserPrefs.SelectedMapId.Value != MapId)
        {
            Navigation.NavigateTo($"/kanban/{UserPrefs.SelectedMapId.Value}", replace: true);
            return;
        }

        _prevMapId       = MapId;
        AllMaps          = (await MapImportSvc.GetAllAsync()).ToList();
        CurrentMap       = AllMaps.FirstOrDefault(m => m.Id == MapId);
        PublishedVersion = await LayoutSvc.GetPublishedVersionAsync(MapId);
        await ReloadAlarms();

        UserPrefs.SetSelectedMapId(MapId);
        await UserPrefs.SaveAsync(JS);
        StartCarousel();

        // W-2: WithUrl requires an absolute URI in Blazor Server; use NavigationManager to resolve.
        HubConn = new HubConnectionBuilder()
            .WithUrl(Navigation.ToAbsoluteUri(KanbanRoutes.AlarmHubPath))
            .Build();

        HubConn.On<int, string, string>(KanbanRoutes.ReceiveAlarmEvent, async (_, _, _) =>
        {
            // W-14: an unhandled exception inside a SignalR receive callback silently kills
            // the connection; catch to keep the hub alive even if the DB is temporarily down.
            try
            {
                await ReloadAlarms();
                await InvokeAsync(StateHasChanged);
            }
            catch { }
        });

        // W-2: StartAsync throws if the hub endpoint is unreachable; catch to avoid
        // crashing OnInitializedAsync and show a recoverable notification instead.
        try
        {
            await HubConn.StartAsync();
        }
        catch (Exception ex)
        {
            NotifySvc.Notify(NotificationSeverity.Warning, "警報連線失敗", ex.Message);
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        if (!CanView || MapId == _prevMapId) return;
        _prevMapId       = MapId;
        IsEditMode       = false;
        DraftId          = null;
        ShowVersions     = false;
        _carouselPaused  = false;
        AllMaps          = (await MapImportSvc.GetAllAsync()).ToList();
        CurrentMap       = AllMaps.FirstOrDefault(m => m.Id == MapId);
        PublishedVersion = await LayoutSvc.GetPublishedVersionAsync(MapId);
        await ReloadAlarms();

        UserPrefs.SetSelectedMapId(MapId);
        await UserPrefs.SaveAsync(JS);
        StartCarousel();
    }

    private void HandleShowVersions()
    {
        ShowVersions = !ShowVersions;
        if (ShowVersions)
        {
            StopCarousel();
            _carouselPaused = true;
        }
        else
        {
            _carouselPaused = false;
            StartCarousel(_carouselRemainingSeconds);
        }
    }

    private Task HandleSaveDraft()
    {
        if (DraftId.HasValue)
            NotifySvc.Notify(NotificationSeverity.Success, "草稿已儲存", $"版本 {DraftId.Value} — 退出後可繼續編輯，點「發布」使其生效");
        else
            NotifySvc.Notify(NotificationSeverity.Warning, "請先進入編輯模式");
        return Task.CompletedTask;
    }

    private async Task HandlePublish()
    {
        if (DraftId == null) { NotifySvc.Notify(NotificationSeverity.Warning, "請先進入編輯模式"); return; }
        try
        {
            var published = await LayoutSvc.PublishAsync(DraftId.Value);
            PublishedVersion = published;
            DraftId          = null;
            _resumeDraftId   = null;
            IsEditMode       = false;   // canvas EndEditSessionAsync will reload published state
            _carouselPaused  = false;
            StartCarousel();
            NotifySvc.Notify(NotificationSeverity.Success, "已發布", $"v{published.VersionNo}");
        }
        catch (Exception ex)
        {
            NotifySvc.Notify(NotificationSeverity.Error, "發布失敗", ex.Message);
        }
    }

    private async Task HandleRollback()
    {
        try
        {
            PublishedVersion = await LayoutSvc.GetPublishedVersionAsync(MapId);
            await InvokeAsync(StateHasChanged);
        }
        catch { }
    }

    private async Task ReloadAlarms()
    {
        ActiveAlarms = (await AlarmSvc.GetActiveAlarmsAsync()).ToList();
    }

    private async Task HandleEditModeChanged(bool val)
    {
        if (val)
        {
            // Check if a saved draft exists so the user can resume it.
            _resumeDraftId = null;
            try
            {
                var versions = await LayoutSvc.GetVersionHistoryAsync(MapId);
                var latestDraft = versions.FirstOrDefault(v => v.Status == LayoutStatus.Draft);
                if (latestDraft != null)
                {
                    var resume = await DialogSvc.Confirm(
                        $"找到先前儲存的草稿（v{latestDraft.VersionNo}），是否繼續上次的編輯工作？",
                        "載入草稿",
                        new ConfirmOptions
                        {
                            OkButtonText     = "繼續編輯",
                            CancelButtonText = "重新開始",
                        });

                    if (resume == null)
                    {
                        // User dismissed the dialog — cancel entering edit mode.
                        IsEditMode = false;
                        return;
                    }
                    _resumeDraftId = resume == true ? latestDraft.Id : null;
                }
            }
            catch { /* version query failure — fall through to fresh draft */ }

            IsEditMode      = true;
            StopCarousel();
            _carouselPaused = false;
        }
        else
        {
            IsEditMode = false;
            _resumeDraftId = null;
            StartCarousel(_carouselRemainingSeconds);
        }
    }

    private void StartCarousel(int resumeFrom = 0)
    {
        StopCarousel();
        if (IsEditMode || CurrentMap == null || !CurrentMap.CarouselEnabled) return;

        var carouselMaps = AllMaps
            .Where(m => m.CarouselEnabled)
            .OrderBy(m => m.CarouselOrder)
            .ThenBy(m => m.Id)
            .ToList();

        if (carouselMaps.Count == 0) return;

        var seconds      = CurrentMap.CarouselSeconds > 0 ? CurrentMap.CarouselSeconds : 10;
        var startSeconds = resumeFrom > 0 ? Math.Min(resumeFrom, seconds) : seconds;
        _carouselCts     = new CancellationTokenSource();
        _ = CarouselTickAsync(MapId, carouselMaps, startSeconds, _carouselCts.Token);
    }

    private async Task CarouselTickAsync(int currentId, List<FactoryMap> maps, int seconds, CancellationToken ct)
    {
        _carouselRemainingSeconds = seconds;
        try
        {
            using var timer = new PeriodicTimer(TimeSpan.FromSeconds(1));
            while (await timer.WaitForNextTickAsync(ct))
            {
                _carouselRemainingSeconds = Math.Max(0, _carouselRemainingSeconds - 1);
                await InvokeAsync(StateHasChanged);
                if (_carouselRemainingSeconds <= 0) break;
            }
            if (!ct.IsCancellationRequested)
            {
                var idx     = maps.FindIndex(m => m.Id == currentId);
                var nextMap = maps[(idx + 1) % maps.Count];
                await InvokeAsync(() => Navigation.NavigateTo($"/kanban/{nextMap.Id}"));
            }
        }
        catch (OperationCanceledException) { }
    }

    private void ToggleCarouselPause()
    {
        _carouselPaused = !_carouselPaused;
        if (_carouselPaused) StopCarousel();
        else                 StartCarousel(_carouselRemainingSeconds);
    }

    private void StopCarousel()
    {
        _carouselCts?.Cancel();
        _carouselCts?.Dispose();
        _carouselCts = null;
    }

    public async ValueTask DisposeAsync()
    {
        StopCarousel();
        if (HubConn != null)
        {
            // W-1: stop the connection gracefully before disposing to avoid leaving a
            // half-open connection on the server side.
            try { await HubConn.StopAsync(); } catch { }
            await HubConn.DisposeAsync();
        }
    }
}
