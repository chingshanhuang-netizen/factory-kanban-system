    private void SelectGalleryIcon(string url)
    {
        _selectedGalleryUrl = url;
        _assignTargetId     = 0;
        _assignCategoryName = string.Empty;
    }

    private async Task DeleteGalleryIcon(string url)
    {
        var usingEquipment = AllEquipment
            .Where(e => e.IconType == IconType.CustomImage && e.IconValue == url)
            .ToList();
        if (usingEquipment.Count > 0)
        {
            var names = string.Join("、", usingEquipment.Take(3).Select(e => e.Name))
                        + (usingEquipment.Count > 3 ? $" 等共 {usingEquipment.Count} 台" : string.Empty);
            await DialogSvc.Alert(
                $"此圖示正在被設備「{names}」使用，無法刪除。\n請先在設備管理中更換這些設備的圖示，再執行刪除。",
                "無法刪除圖示",
                new AlertOptions { OkButtonText = "確定" });
            return;
        }
        var confirmed = await DialogSvc.Confirm(
            "確定要刪除此圖示嗎？此操作無法復原。",
            "刪除圖示",
            new ConfirmOptions { OkButtonText = "刪除", CancelButtonText = "取消" });
        if (confirmed != true) return;
        try
        {
            await GallerySvc.DeleteAsync(url);
            try { await AuditSvc.LogDeleteAsync("圖示", 0, $"gallery:{url[..Math.Min(40, url.Length)]}...", CurrentUser.GetCurrentUser()); } catch { }
            if (_selectedGalleryUrl == url) _selectedGalleryUrl = string.Empty;
            await RefreshGallery();
            NotifySvc.Notify(NotificationSeverity.Success, "圖示已刪除");
        }
        catch (Exception ex)
        {
            NotifySvc.Notify(NotificationSeverity.Error, "刪除圖示失敗", ex.Message);
        }
    }

    private async Task EditGalleryIcon(string url)
    {
        var newUrl = await DialogSvc.OpenAsync<IconReplaceDialog>(
            "替換圖示",
            new Dictionary<string, object> { { "OldIconUrl", url } },
            new DialogOptions { Width = "420px", CloseDialogOnOverlayClick = false, Draggable = true });
        if (newUrl is not string replacement || string.IsNullOrEmpty(replacement)) return;
        try
        {
            await GallerySvc.UpdateAsync(url, replacement);
            foreach (var eq in AllEquipment.Where(e => e.IconType == IconType.CustomImage && e.IconValue == url))
            {
                eq.IconValue = replacement;
                await EquipmentSvc.UpdateEquipmentAsync(eq);
            }
            AllEquipment = (await EquipmentSvc.GetAllEquipmentAsync()).ToList();
            await (_equipGrid?.Reload() ?? Task.CompletedTask);
            if (_selectedGalleryUrl == url) _selectedGalleryUrl = replacement;
            await RefreshGallery();
            NotifySvc.Notify(NotificationSeverity.Success, "圖示已替換");
        }
        catch (Exception ex)
        {
            NotifySvc.Notify(NotificationSeverity.Error, "替換圖示失敗", ex.Message);
        }
    }

    private async Task AssignIconToCategory()
    {
        if (string.IsNullOrEmpty(_assignCategoryName) || string.IsNullOrEmpty(_selectedGalleryUrl)) return;
        var toUpdate = AllEquipment.Where(e => e.Category == _assignCategoryName).ToList();
        if (toUpdate.Count == 0) return;
        try
        {
            foreach (var eq in toUpdate)
            {
                eq.IconType  = IconType.CustomImage;
                eq.IconValue = _selectedGalleryUrl;
                await EquipmentSvc.UpdateEquipmentAsync(eq);
            }
            AllEquipment = (await EquipmentSvc.GetAllEquipmentAsync()).ToList();
