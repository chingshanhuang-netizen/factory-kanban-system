    private async Task DeleteEquipment(int id)
    {
        var eq = AllEquipment.FirstOrDefault(e => e.Id == id);
        var name = eq?.Name ?? id.ToString();

        bool inUse;
        try { inUse = await EquipmentSvc.IsEquipmentInUseAsync(id); }
        catch (Exception ex)
        {
            NotifySvc.Notify(NotificationSeverity.Error, "無法驗證設備狀態", ex.Message);
            return;
        }

        if (inUse)
        {
            NotifySvc.Notify(NotificationSeverity.Warning, "無法刪除設備",
                $"「{name}」已配置在看板地圖上，請先移除版面上的 Widget 再刪除。");
            await DialogSvc.Alert(
                $"設備「{name}」已配置在看板地圖上，無法刪除。\n請先從地圖版面中移除該設備的 Widget，再執行刪除。",
                "無法刪除設備",
                new AlertOptions { OkButtonText = "確定" });
            return;
        }

        var confirmed = await DialogSvc.Confirm(
            $"確定要刪除設備「{name}」嗎？此操作無法復原。",
            "刪除設備",
            new ConfirmOptions { OkButtonText = "刪除", CancelButtonText = "取消" });
        if (confirmed != true) return;

        try
        {
            await EquipmentSvc.DeleteEquipmentAsync(id);
            try { await AuditSvc.LogDeleteAsync("設備", id, name, CurrentUser.GetCurrentUser()); } catch { }
            AllEquipment.RemoveAll(e => e.Id == id);
            await (_equipGrid?.Reload() ?? Task.CompletedTask);
            await RefreshGallery();
            NotifySvc.Notify(NotificationSeverity.Success, "設備已刪除", name);
        }
        catch (Exception ex)
        {
            NotifySvc.Notify(NotificationSeverity.Error, "刪除設備失敗", ex.Message);
        }
    }

