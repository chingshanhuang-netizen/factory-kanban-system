    private async Task AddDataType()
    {
        var allExisting = AllDataSources
            .Where(d => !string.IsNullOrEmpty(d.DataType))
            .Select(d => d.DataType!)
            .Union(_extraDataTypes)
            .Distinct()
            .OrderBy(t => t)
            .ToList();
        var result = await DialogSvc.OpenAsync<DataTypeCreateDialog>(
            "新增資料類型",
            new Dictionary<string, object> { { "ExistingDataTypes", allExisting } },
            new DialogOptions { Width = "420px", CloseDialogOnOverlayClick = false, Draggable = true });
        if (result is string name && !string.IsNullOrWhiteSpace(name)
            && !_extraDataTypes.Contains(name))
        {
            _extraDataTypes.Add(name);
            NotifySvc.Notify(NotificationSeverity.Success, "資料類型已新增", $"「{name}」已加入資料類型清單");
        }
    }

