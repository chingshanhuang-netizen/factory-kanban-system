    private async Task OnIconFileSelected(InputFileChangeEventArgs args)
    {
        _iconFileBytes     = null;
        _iconFileName      = string.Empty;
        _localPreviewUrl   = string.Empty;
        _assignTargetId    = 0;
        _iconStatusMessage = string.Empty;
        try
        {
            var file = args.File;
            // Read immediately — IBrowserFile JS ref becomes invalid after re-render
            await using var src = file.OpenReadStream(maxAllowedSize: ModuleOpts.Value.IconUploadMaxBytes);
            using var ms        = new MemoryStream();
            await src.CopyToAsync(ms);
            _iconFileBytes   = ms.ToArray();
            _iconFileName    = file.Name;
            _localPreviewUrl = $"data:{_iconFormat.MimeType};base64,{Convert.ToBase64String(_iconFileBytes)}";
        }
        catch (Exception ex)
        {
            _iconIsError       = true;
            _iconStatusMessage = $"❌ 讀取圖示失敗：{ex.Message}";
        }
    }

    private async Task DoIconUpload()
    {
        if (_iconFileBytes == null || string.IsNullOrEmpty(_iconFileName)) return;
        _iconIsError       = false;
        _iconStatusMessage = "上傳中...";
        try
        {
            using var stream    = new MemoryStream(_iconFileBytes);
            var url             = await IconSvc.UploadAsync(stream, _iconFileName);
            await GallerySvc.AddAsync(url);
            _iconStatusMessage  = $"✅ 已匯入：{_iconFileName}";
            _localPreviewUrl    = string.Empty;
            _iconFileBytes      = null;
            _iconFileName       = string.Empty;
            await RefreshGallery();
            _selectedGalleryUrl = url;
            _assignTargetId     = 0;
            StateHasChanged();
            NotifySvc.Notify(NotificationSeverity.Success, "圖示已上傳，已加入圖示庫");
        }
        catch (Exception ex)
        {
            _iconIsError       = true;
            _iconStatusMessage = $"❌ 上傳失敗：{ex.Message}";
            NotifySvc.Notify(NotificationSeverity.Error, "上傳圖示失敗", ex.Message);
        }
    }

    private async Task AssignIconToEquipment()
    {
        var eq = AllEquipment.FirstOrDefault(e => e.Id == _assignTargetId);
        if (eq == null || string.IsNullOrEmpty(_selectedGalleryUrl)) return;
        try
        {
            eq.IconType  = IconType.CustomImage;
            eq.IconValue = _selectedGalleryUrl;
            await EquipmentSvc.UpdateEquipmentAsync(eq);
            AllEquipment = (await EquipmentSvc.GetAllEquipmentAsync()).ToList();
            await (_equipGrid?.Reload() ?? Task.CompletedTask);
            await RefreshGallery();
            NotifySvc.Notify(NotificationSeverity.Success, "圖示已套用", $"已將圖示套用至「{eq.Name}」");
            _assignTargetId = 0;
        }
        catch (Exception ex)
        {
            NotifySvc.Notify(NotificationSeverity.Error, "套用圖示失敗", ex.Message);
        }
    }

