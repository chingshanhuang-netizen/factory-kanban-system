@page "/kanban/settings"
@inject IEquipmentService EquipmentSvc
@inject IIconUploadService IconSvc
@inject IFunctionPermissionService PermSvc
@inject IMapImportService MapImportSvc
@inject NotificationService NotifySvc
@inject DialogService DialogSvc
@inject IIconGalleryService GallerySvc
@inject IOptions<KanbanModuleOptions> ModuleOpts
@inject IJSRuntime JS
@inject UserPrefsService UserPrefs

<PageTitle>看板設定</PageTitle>

@if (!CanSettings)
{
    <div style="padding:40px;text-align:center;color:#f44336">無設定權限（需要 @KanbanPermissions.Settings）</div>
    return;
}

<div style="padding:16px">
    <RadzenText TextStyle="TextStyle.H5">看板設定</RadzenText>

    <RadzenTabs>
        <Tabs>

            <!-- ── 設備管理 ─────────────────────────────────────────────── -->
            <RadzenTabsItem Text="設備管理">
                <div style="margin-bottom:10px;display:flex;gap:8px;align-items:center">
                    <RadzenButton Text="+ 新增類別" ButtonStyle="ButtonStyle.Secondary"
                                  Size="ButtonSize.Small" Click="@AddCategory" />
                    <RadzenButton Text="+ 新增設備" ButtonStyle="ButtonStyle.Primary"
                                  Size="ButtonSize.Small" Click="@AddEquipment" />
                    <RadzenButton Icon="settings" Text="欄位設定"
                                  ButtonStyle="@(_showEquipCols ? ButtonStyle.Info : ButtonStyle.Light)"
                                  Size="ButtonSize.Small"
                                  Click="@(() => _showEquipCols = !_showEquipCols)" />
                    <span style="flex:1"></span>
                    <input type="text" @bind="_equipSearch" @bind:event="oninput"
                           placeholder="🔍 搜尋設備..."
                           style="background:rgba(255,255,255,.07);border:1px solid #2a4a6c;
                                  color:#c8d8e8;border-radius:4px;padding:4px 10px;
                                  font-size:0.85em;outline:none;width:180px" />
                </div>

                @if (_showEquipCols)
                {
                    <ColumnSettingsPanel Prefs="@_equipCols"
                                         OnReordered="@(() => _equipGridKey++)" />
                }

                <RadzenDataGrid @key="@_equipGridKey" @ref="_equipGrid"
                                Data="@FilteredEquipment" TItem="Equipment"
                                AllowSorting="true" AllowFiltering="true" FilterMode="FilterMode.Simple"
                                AllowPaging="true" PageSize="@_equipPageSize"
                                PageSizeOptions="@(new int[]{10,20,50,100})"
                                Page="@((args) => _equipPage = args.PageIndex)"
                                PageSizeChanged="@((size) => { _equipPageSize = size; _equipPage = 0; })"
                                ShowPagingSummary="true" PagingSummaryFormat="@EquipSummary"
                                AllowColumnResize="true" class="kanban-light-grid"
                                Style="height: calc(100vh - 242px)"
                                ColumnResized="@OnEquipColResized">
                    <Columns>
                        @foreach (var colId in _equipCols.Order)
                        {
                            if (colId == "name")
                            {
                                <RadzenDataGridColumn @key="@colId" TItem="Equipment"
                                                      Property="Name" Title="名稱"
                                                      Width="@_equipCols.Width("name")" MinWidth="80px" />
                            }
                            else if (colId == "category")
                            {
                                <RadzenDataGridColumn @key="@colId" TItem="Equipment"
                                                      Property="Category" Title="類別"
                                                      Width="@_equipCols.Width("category")" MinWidth="80px" />
                            }
                            else if (colId == "tag")
                            {
                                <RadzenDataGridColumn @key="@colId" TItem="Equipment"
                                                      Property="Tag" Title="標籤"
                                                      Width="@_equipCols.Width("tag")" MinWidth="60px" />
                            }
                            else if (colId == "mapName")
                            {
                                <RadzenDataGridColumn @key="@colId" TItem="Equipment"
                                                      Property="MapName" Title="地圖名稱"
                                                      Width="@_equipCols.Width("mapName")" MinWidth="80px" />
                            }
                            else if (colId == "icon")
                            {
                                <RadzenDataGridColumn @key="@colId" TItem="Equipment"
                                                      Title="圖示"
                                                      Width="@_equipCols.Width("icon")"
                                                      Resizable="false">
                                    <Template Context="eq">
                                        <EquipmentIconRenderer Equipment="@eq" />
                                    </Template>
                                </RadzenDataGridColumn>
                            }
                            else if (colId == "actions")
                            {
                                <RadzenDataGridColumn @key="@colId" TItem="Equipment"
                                                      Title="操作"
                                                      Width="@_equipCols.Width("actions")"
                                                      Resizable="false">
                                    <Template Context="eq">
                                        <RadzenButton Text="編輯" Size="ButtonSize.ExtraSmall"
                                                      Click="@(() => EditEquipment(eq))" />
                                        <RadzenButton Text="刪除" Size="ButtonSize.ExtraSmall"
                                                      ButtonStyle="ButtonStyle.Danger"
                                                      Click="@(() => DeleteEquipment(eq.Id))"
                                                      Style="margin-left:4px" />
                                    </Template>
                                </RadzenDataGridColumn>
                            }
                        }
                    </Columns>
                </RadzenDataGrid>
            </RadzenTabsItem>

            <!-- ── 資料來源 ─────────────────────────────────────────────── -->
            <RadzenTabsItem Text="資料來源">
                <div style="margin-bottom:10px;display:flex;gap:8px;align-items:center">
                    <RadzenButton Text="+ 新增資料類型" ButtonStyle="ButtonStyle.Secondary"
                                  Size="ButtonSize.Small" Click="@AddDataType" />
                    <RadzenButton Text="+ 新增資料來源" ButtonStyle="ButtonStyle.Primary"
                                  Size="ButtonSize.Small" Click="@AddDataSource" />
                    <RadzenButton Icon="settings" Text="欄位設定"
                                  ButtonStyle="@(_showDsCols ? ButtonStyle.Info : ButtonStyle.Light)"
                                  Size="ButtonSize.Small"
                                  Click="@(() => _showDsCols = !_showDsCols)" />
                    <span style="flex:1"></span>
                    <input type="text" @bind="_dsSearch" @bind:event="oninput"
                           placeholder="🔍 搜尋資料來源..."
                           style="background:rgba(255,255,255,.07);border:1px solid #2a4a6c;
                                  color:#c8d8e8;border-radius:4px;padding:4px 10px;
                                  font-size:0.85em;outline:none;width:180px" />
                </div>

                @if (_showDsCols)
                {
                    <ColumnSettingsPanel Prefs="@_dsCols"
                                         OnReordered="@(() => _dsGridKey++)" />
                }

                <RadzenDataGrid @key="@_dsGridKey" @ref="_dsGrid"
                                Data="@FilteredDataSources" TItem="DataSourceConfig"
                                AllowSorting="true" AllowFiltering="true" FilterMode="FilterMode.Simple"
                                AllowPaging="true" PageSize="@_dsPageSize"
                                PageSizeOptions="@(new int[]{10,20,50,100})"
                                Page="@((args) => _dsPage = args.PageIndex)"
                                PageSizeChanged="@((size) => { _dsPageSize = size; _dsPage = 0; })"
                                ShowPagingSummary="true" PagingSummaryFormat="@DsSummary"
                                AllowColumnResize="true" class="kanban-light-grid"
                                Style="height: calc(100vh - 242px)"
                                ColumnResized="@OnDsColResized">
                    <Columns>
                        @foreach (var colId in _dsCols.Order)
                        {
                            if (colId == "name")
                            {
                                <RadzenDataGridColumn @key="@colId" TItem="DataSourceConfig"
                                                      Property="Name" Title="名稱"
                                                      Width="@_dsCols.Width("name")" MinWidth="80px" />
                            }
                            else if (colId == "dataType")
                            {
                                <RadzenDataGridColumn @key="@colId" TItem="DataSourceConfig"
                                                      Property="DataType" Title="資料類型"
                                                      Width="@_dsCols.Width("dataType")" MinWidth="60px" />
                            }
                            else if (colId == "sourceType")
                            {
                                <RadzenDataGridColumn @key="@colId" TItem="DataSourceConfig"
                                                      Property="SourceType" Title="類型"
                                                      Width="@_dsCols.Width("sourceType")" MinWidth="60px" />
                            }
                            else if (colId == "queryOrPath")
                            {
                                <RadzenDataGridColumn @key="@colId" TItem="DataSourceConfig"
                                                      Property="QueryOrPath" Title="查詢/路徑"
                                                      Width="@_dsCols.Width("queryOrPath")" MinWidth="80px" />
                            }
                            else if (colId == "actions")
                            {
                                <RadzenDataGridColumn @key="@colId" TItem="DataSourceConfig"
                                                      Title="操作"
                                                      Width="@_dsCols.Width("actions")"
                                                      Resizable="false">
                                    <Template Context="ds">
                                        <RadzenButton Text="編輯" Size="ButtonSize.ExtraSmall"
                                                      Click="@(() => EditDataSource(ds))" />
                                        <RadzenButton Text="刪除" Size="ButtonSize.ExtraSmall"
                                                      ButtonStyle="ButtonStyle.Danger"
                                                      Click="@(() => DeleteDataSource(ds.Id))"
                                                      Style="margin-left:4px" />
                                    </Template>
                                </RadzenDataGridColumn>
                            }
                        }
                    </Columns>
                </RadzenDataGrid>
            </RadzenTabsItem>

            <!-- ── 圖示上傳 ─────────────────────────────────────────────── -->
            <RadzenTabsItem Text="圖示上傳">
                <div style="display:flex;flex-direction:column;gap:16px;padding:4px 0;max-width:720px">

                    <RadzenCard>
                        <RadzenText TextStyle="TextStyle.Subtitle1" Style="margin-bottom:12px">上傳新圖示</RadzenText>
                        <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap">
                            <InputFile OnChange="@OnIconFileSelected"
                                       accept=".png,.jpg,.jpeg,.svg"
                                       style="flex:1;min-width:200px;color:#aaa" />
                            <RadzenButton Text="上傳" ButtonStyle="ButtonStyle.Primary"
                                          Size="ButtonSize.Small"
                                          Disabled="@(_iconFileBytes == null)"
                                          Click="@DoIconUpload" />
                        </div>
                        @if (!string.IsNullOrEmpty(_localPreviewUrl))
                        {
                            <div style="display:flex;align-items:center;gap:10px;margin-top:10px;
                                        padding:8px;background:rgba(255,255,255,.05);border-radius:4px">
                                <img src="@_localPreviewUrl" alt="預覽"
                                     style="width:40px;height:40px;object-fit:contain" />
                                <span style="color:#aaa;font-size:0.85em">選取預覽（尚未上傳）</span>
                            </div>
                        }
                    </RadzenCard>

                    <RadzenCard>
                        <RadzenText TextStyle="TextStyle.Subtitle1" Style="margin-bottom:4px">
                            圖示庫
                            @if (_allGalleryIcons.Count > 0)
                            {
                                <span style="color:#aaa;font-size:0.82em;margin-left:6px">（共 @_allGalleryIcons.Count 個，點選後可套用到設備）</span>
                            }
                        </RadzenText>
                        @if (_allGalleryIcons.Count == 0)
                        {
                            <p style="color:#666;font-size:0.85em;margin:8px 0 0">尚無圖示，請先上傳。</p>
                        }
                        else
                        {
                            <div style="display:flex;flex-wrap:wrap;gap:8px;margin-top:10px">
                                @foreach (var (url, idx) in _allGalleryIcons.Select((u, i) => (u, i)))
                                {
                                    var isSelected = url == _selectedGalleryUrl;
                                    <div @key="@idx"
                                         @onclick="@(() => SelectGalleryIcon(url))"
                                         title="點擊選取"
                                         style="width:56px;height:56px;cursor:pointer;border-radius:6px;
                                                border:2px solid @(isSelected ? "#4caf50" : "rgba(255,255,255,.15)");
                                                background:rgba(255,255,255,.06);padding:4px;
                                                box-sizing:border-box">
                                        <img src="@url" style="width:100%;height:100%;object-fit:contain" />
                                    </div>
                                }
                            </div>
                        }
                    </RadzenCard>

                    @if (!string.IsNullOrEmpty(_selectedGalleryUrl))
                    {
                        <RadzenCard>
                            <div style="display:flex;align-items:center;gap:12px;margin-bottom:14px">
                                <img src="@_selectedGalleryUrl" alt="已選圖示"
                                     style="width:48px;height:48px;object-fit:contain;flex-shrink:0;
                                            background:rgba(255,255,255,.06);border-radius:4px;padding:4px;
                                            border:2px solid #4caf50" />
                                <RadzenText TextStyle="TextStyle.Subtitle1">套用到</RadzenText>
                                <RadzenRadioButtonList @bind-Value="_assignToCategory"
                                                       TValue="bool"
                                                       Orientation="Orientation.Horizontal">
                                    <Items>
                                        <RadzenRadioButtonListItem Text="設備類別" Value="@true" />
                                        <RadzenRadioButtonListItem Text="指定設備" Value="@false" />
                                    </Items>
                                </RadzenRadioButtonList>
                            </div>
                            @if (_assignToCategory)
                            {
                                <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap">
                                    <RadzenDropDown @bind-Value="_assignCategoryName"
                                                    Data="@_allCategories" TValue="string"
                                                    Placeholder="選擇類別..."
                                                    Style="flex:1;min-width:160px" />
                                    <RadzenButton Text="套用到此類別" ButtonStyle="ButtonStyle.Success"
                                                  Size="ButtonSize.Small"
                                                  Disabled="@string.IsNullOrEmpty(_assignCategoryName)"
                                                  Click="@AssignIconToCategory" />
                                </div>
                                @if (!string.IsNullOrEmpty(_assignCategoryName))
                                {
                                    var count = AllEquipment.Count(e => e.Category == _assignCategoryName);
                                    <div style="margin-top:8px;font-size:0.82em;color:#aaa">
                                        將套用到「@_assignCategoryName」類別共 @count 台設備
                                    </div>
                                }
                            }
                            else
                            {
                                <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap">
                                    <RadzenDropDown @bind-Value="_assignTargetId"
                                                    Data="@_equipmentDisplayItems"
                                                    TextProperty="DisplayText" ValueProperty="Id"
                                                    TValue="int"
                                                    Placeholder="選擇設備..."
                                                    Style="flex:1;min-width:200px" />
                                    <RadzenButton Text="套用" ButtonStyle="ButtonStyle.Success"
                                                  Size="ButtonSize.Small"
                                                  Disabled="@(_assignTargetId == 0)"
                                                  Click="@AssignIconToEquipment" />
                                </div>
                                @if (_assignTargetId > 0)
                                {
                                    var targetEq = AllEquipment.FirstOrDefault(e => e.Id == _assignTargetId);
                                    if (targetEq != null)
                                    {
                                        <div style="display:flex;align-items:center;gap:8px;margin-top:8px;
                                                    padding:8px;background:rgba(255,255,255,.04);border-radius:4px;
                                                    font-size:0.85em;color:#aaa">
                                            <span>目前：</span>
                                            <EquipmentIconRenderer Equipment="@targetEq" />
                                            <span>→</span>
                                            <img src="@_selectedGalleryUrl"
                                                 style="width:1.5em;height:1.5em;object-fit:contain" />
                                            <span>@targetEq.Name</span>
                                        </div>
                                    }
                                }
                            }
                        </RadzenCard>
                    }

                </div>
            </RadzenTabsItem>

            <!-- ── 地圖管理 ─────────────────────────────────────────────── -->
            <RadzenTabsItem Text="地圖管理">
                <MapImportPanel OnImported="@OnMapImported" />
                <div style="margin-top:16px">
                    <div style="display:flex;align-items:center;gap:8px;margin-bottom:10px">
                        <RadzenText TextStyle="TextStyle.Subtitle1">已匯入地圖</RadzenText>
                        <RadzenButton Icon="settings" Text="欄位設定"
                                      ButtonStyle="@(_showMapCols ? ButtonStyle.Info : ButtonStyle.Light)"
                                      Size="ButtonSize.Small"
                                      Click="@(() => _showMapCols = !_showMapCols)" />
                        <span style="flex:1"></span>
                        <input type="text" @bind="_mapSearch" @bind:event="oninput"
                               placeholder="🔍 搜尋地圖..."
                               style="background:rgba(255,255,255,.07);border:1px solid #2a4a6c;
                                      color:#c8d8e8;border-radius:4px;padding:4px 10px;
                                      font-size:0.85em;outline:none;width:180px" />
                    </div>

                    @if (_showMapCols)
                    {
                        <ColumnSettingsPanel Prefs="@_mapCols"
                                             OnReordered="@(() => _mapGridKey++)" />
                    }

                    <RadzenDataGrid @key="@_mapGridKey" Data="@FilteredMaps" TItem="FactoryMap"
                                    AllowSorting="true" AllowFiltering="true" FilterMode="FilterMode.Simple"
                                    AllowPaging="true" PageSize="@_mapPageSize"
                                    PageSizeOptions="@(new int[]{10,20,50,100})"
                                    Page="@((args) => _mapPage = args.PageIndex)"
                                    PageSizeChanged="@((size) => { _mapPageSize = size; _mapPage = 0; })"
                                    ShowPagingSummary="true" PagingSummaryFormat="@MapSummary"
                                    AllowColumnResize="true" class="kanban-light-grid"
                                    Style="height: calc(100vh - 420px)"
                                    ColumnResized="@OnMapColResized">
                        <Columns>
                            @foreach (var colId in _mapCols.Order)
                            {
                                if (colId == "name")
                                {
                                    <RadzenDataGridColumn @key="@colId" TItem="FactoryMap"
                                                          Property="Name" Title="名稱"
                                                          Width="@_mapCols.Width("name")" MinWidth="80px" />
                                }
                                else if (colId == "floor")
                                {
                                    <RadzenDataGridColumn @key="@colId" TItem="FactoryMap"
                                                          Property="Floor" Title="樓層"
                                                          Width="@_mapCols.Width("floor")" MinWidth="60px" />
                                }
                                else if (colId == "area")
                                {
                                    <RadzenDataGridColumn @key="@colId" TItem="FactoryMap"
                                                          Property="Area" Title="區域"
                                                          Width="@_mapCols.Width("area")" MinWidth="60px" />
                                }
                                else if (colId == "formatType")
                                {
                                    <RadzenDataGridColumn @key="@colId" TItem="FactoryMap"
                                                          Property="FormatType" Title="格式"
                                                          Width="@_mapCols.Width("formatType")" MinWidth="60px" />
                                }
                                else if (colId == "createdAt")
                                {
                                    <RadzenDataGridColumn @key="@colId" TItem="FactoryMap"
                                                          Property="CreatedAt" Title="建立時間"
                                                          FormatString="{0:yyyy-MM-dd}"
                                                          Width="@_mapCols.Width("createdAt")" MinWidth="80px" />
                                }
                                else if (colId == "carousel")
                                {
                                    <RadzenDataGridColumn @key="@colId" TItem="FactoryMap"
                                                          Title="輪播"
                                                          Width="@_mapCols.Width("carousel")" MinWidth="50px"
                                                          Resizable="false">
                                        <Template Context="m">
                                            <RadzenCheckBox Value="@m.CarouselEnabled"
                                                            Change="@((bool val) => ToggleMapCarousel(m, val))" />
                                        </Template>
                                    </RadzenDataGridColumn>
                                }
                                else if (colId == "carouselOrder")
                                {
                                    <RadzenDataGridColumn @key="@colId" TItem="FactoryMap"
                                                          Property="CarouselOrder" Title="次序"
                                                          Width="@_mapCols.Width("carouselOrder")" MinWidth="50px" />
                                }
                                else if (colId == "carouselSecs")
                                {
                                    <RadzenDataGridColumn @key="@colId" TItem="FactoryMap"
                                                          Property="CarouselSeconds" Title="時間(秒)"
                                                          Width="@_mapCols.Width("carouselSecs")" MinWidth="60px" />
                                }
                                else if (colId == "actions")
                                {
                                    <RadzenDataGridColumn @key="@colId" TItem="FactoryMap"
                                                          Title="操作"
                                                          Width="@_mapCols.Width("actions")"
                                                          Resizable="false">
                                        <Template Context="m">
                                            <RadzenButton Text="編輯" Size="ButtonSize.ExtraSmall"
                                                          Click="@(() => EditMap(m))" />
                                            <RadzenButton Text="取消" Size="ButtonSize.ExtraSmall"
                                                          ButtonStyle="ButtonStyle.Danger"
                                                          Click="@(() => DeleteMap(m.Id))"
                                                          Style="margin-left:4px" />
                                        </Template>
                                    </RadzenDataGridColumn>
                                }
                            }
                        </Columns>
                    </RadzenDataGrid>
                </div>
            </RadzenTabsItem>

        </Tabs>
    </RadzenTabs>
</div>

@code {
    private bool CanSettings;
    private List<Equipment>        AllEquipment   = new();
    private List<DataSourceConfig> AllDataSources = new();
    private List<FactoryMap>       AllMaps        = new();
    private RadzenDataGrid<Equipment>?        _equipGrid;
    private RadzenDataGrid<DataSourceConfig>? _dsGrid;

    private byte[]? _iconFileBytes;
    private string  _iconFileName    = string.Empty;
    private string  _localPreviewUrl = string.Empty;
    private List<string> _allGalleryIcons = new();
    private string  _selectedGalleryUrl  = string.Empty;
    private bool    _assignToCategory;
    private string  _assignCategoryName = string.Empty;
    private int     _assignTargetId;
    private List<string> _extraCategories = new();
    private List<string> _extraDataTypes  = new();

    // ── Column preferences — initialised in OnInitializedAsync after DI is ready ─
    private GridColumnPrefs _equipCols = null!;
    private GridColumnPrefs _dsCols    = null!;
    private GridColumnPrefs _mapCols   = null!;

    private bool   _showEquipCols;
    private bool   _showDsCols;
    private bool   _showMapCols;
    private int    _equipGridKey;
    private int    _dsGridKey;
    private int    _mapGridKey;
    private bool   _prefsLoaded;
    private string _equipSearch = "";
    private string _dsSearch    = "";
    private string _mapSearch   = "";

    // ── Pager state ─────────────────────────────────────────────────────────
    private int _equipPage = 0, _equipPageSize = 10;
    private int _dsPage    = 0, _dsPageSize    = 10;
    private int _mapPage   = 0, _mapPageSize   = 10;

    private string EquipSummary => GridPageSummary(_equipPage, _equipPageSize, FilteredEquipment.Count());
    private string DsSummary    => GridPageSummary(_dsPage,    _dsPageSize,    FilteredDataSources.Count());
    private string MapSummary   => GridPageSummary(_mapPage,   _mapPageSize,   FilteredMaps.Count());

    private static string GridPageSummary(int page0, int size, int total)
    {
        var pages = total == 0 ? 1 : (int)Math.Ceiling((double)total / size);
        return $"Page {page0 + 1} of {pages} ({total} Items)";
    }

    private IEnumerable<Equipment> FilteredEquipment => string.IsNullOrWhiteSpace(_equipSearch)
        ? AllEquipment
        : AllEquipment.Where(e =>
            (e.Name?.Contains(_equipSearch,     StringComparison.OrdinalIgnoreCase) == true) ||
            (e.Tag?.Contains(_equipSearch,      StringComparison.OrdinalIgnoreCase) == true) ||
            (e.Category?.Contains(_equipSearch, StringComparison.OrdinalIgnoreCase) == true) ||
            (e.MapName?.Contains(_equipSearch,  StringComparison.OrdinalIgnoreCase) == true));

    private IEnumerable<DataSourceConfig> FilteredDataSources => string.IsNullOrWhiteSpace(_dsSearch)
        ? AllDataSources
        : AllDataSources.Where(d =>
            (d.Name?.Contains(_dsSearch,        StringComparison.OrdinalIgnoreCase) == true) ||
            (d.DataType?.Contains(_dsSearch,    StringComparison.OrdinalIgnoreCase) == true) ||
            (d.QueryOrPath?.Contains(_dsSearch, StringComparison.OrdinalIgnoreCase) == true) ||
            d.SourceType.ToString().Contains(_dsSearch, StringComparison.OrdinalIgnoreCase));

    private IEnumerable<FactoryMap> FilteredMaps => string.IsNullOrWhiteSpace(_mapSearch)
        ? AllMaps
        : AllMaps.Where(m =>
            (m.Name?.Contains(_mapSearch,   StringComparison.OrdinalIgnoreCase) == true) ||
            (m.Floor?.Contains(_mapSearch,  StringComparison.OrdinalIgnoreCase) == true) ||
            (m.Area?.Contains(_mapSearch,   StringComparison.OrdinalIgnoreCase) == true));
    // ──────────────────────────────────────────────────────────────────────

    private IEnumerable<string> _allCategories => AllEquipment
        .Where(e => !string.IsNullOrEmpty(e.Category))
        .Select(e => e.Category!)
        .Union(_extraCategories)
        .Distinct()
        .OrderBy(c => c);

    private record EquipmentDisplayItem(int Id, string DisplayText);
    private IEnumerable<EquipmentDisplayItem> _equipmentDisplayItems => AllEquipment
        .Select(e => new EquipmentDisplayItem(
            e.Id,
            string.Join(".", new[] { e.Category, e.Name, e.Tag }
                .Where(s => !string.IsNullOrEmpty(s)))));

    protected override async Task OnInitializedAsync()
    {
        _equipCols = new("equip", new[]
        {
            new GridColumnPrefs.ColDef("name",     "名稱"),
            new GridColumnPrefs.ColDef("category", "類別"),
            new GridColumnPrefs.ColDef("tag",      "標籤"),
            new GridColumnPrefs.ColDef("mapName",  "地圖名稱"),
            new GridColumnPrefs.ColDef("icon",     "圖示",    64,  false),
            new GridColumnPrefs.ColDef("actions",  "操作",   120,  false),
        }, UserPrefs);
