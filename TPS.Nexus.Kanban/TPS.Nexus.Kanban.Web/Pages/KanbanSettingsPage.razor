    private static string IconFileName(string url)
    {
        try { return Uri.UnescapeDataString(new Uri(url).Segments.Last()); }
        catch
        {
            var i = url.LastIndexOf('/');
            return i >= 0 ? url[(i + 1)..] : url;
        }
    }

    private static string IconFormat(string url)
    {
        var name = IconFileName(url);
        var dot  = name.LastIndexOf('.');
        return dot >= 0 ? name[(dot + 1)..].ToUpperInvariant() : "—";
    }

    private static string FormatColor(string fmt) => fmt switch
