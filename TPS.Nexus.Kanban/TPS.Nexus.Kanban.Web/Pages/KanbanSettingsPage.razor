        bool hasVersions;
        try { hasVersions = await MapImportSvc.HasLayoutVersionsAsync(id); }
        catch (Exception ex)
        {
            NotifySvc.Notify(NotificationSeverity.Error, "無法驗證地圖狀態", ex.Message);
