        {
            new GridColumnPrefs.ColDef("name",        "名稱"),
            new GridColumnPrefs.ColDef("dataType",    "資料類型"),
            new GridColumnPrefs.ColDef("sourceType",  "類型",    80),
            new GridColumnPrefs.ColDef("queryOrPath", "查詢/路徑"),
            new GridColumnPrefs.ColDef("actions",     "操作",   140, false),
        }, UserPrefs);
        _mapCols = new("map", new[]
        {
            new GridColumnPrefs.ColDef("name",           "名稱"),
            new GridColumnPrefs.ColDef("floor",          "樓層",        80),
            new GridColumnPrefs.ColDef("area",           "區域",        80),
            new GridColumnPrefs.ColDef("formatType",     "格式",        80),
            new GridColumnPrefs.ColDef("createdAt",      "建立時間",   100),
            new GridColumnPrefs.ColDef("carousel",       "輪播",        60, false),
            new GridColumnPrefs.ColDef("carouselOrder",  "次序",        60),
            new GridColumnPrefs.ColDef("carouselSecs",   "時間(秒)",    70),
            new GridColumnPrefs.ColDef("actions",        "操作",       140, false),
        }, UserPrefs);

        CanSettings = await PermSvc.HasPermissionAsync(KanbanPermissions.Settings);
        if (!CanSettings) return;
