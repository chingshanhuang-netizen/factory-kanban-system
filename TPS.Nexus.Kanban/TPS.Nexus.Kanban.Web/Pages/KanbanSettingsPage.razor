    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && CanSettings && !_prefsLoaded)
        {
            _prefsLoaded = true;
            await _equipCols.LoadAsync(JS);
            await _dsCols.LoadAsync(JS);
            await _mapCols.LoadAsync(JS);
            StateHasChanged();
        }
    }

    private async Task LoadAll()
    {
        AllEquipment   = (await EquipmentSvc.GetAllEquipmentAsync()).ToList();
        AllDataSources = (await EquipmentSvc.GetAllDataSourceConfigsAsync()).ToList();
        AllMaps        = (await MapImportSvc.GetAllAsync()).ToList();
        await RefreshGallery();
    }

    private async Task RefreshGallery()
    {
        var fromGallery   = await GallerySvc.GetAllAsync();
        var fromEquipment = AllEquipment
            .Where(e => e.IconType == IconType.CustomImage && !string.IsNullOrEmpty(e.IconValue))
            .Select(e => e.IconValue!);
        _allGalleryIcons = fromGallery.Union(fromEquipment).ToList();
    }

