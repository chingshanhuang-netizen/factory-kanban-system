@page "/kanban/settings"
@inject IEquipmentService EquipmentSvc
@inject IIconUploadService IconSvc
@inject IFunctionPermissionService PermSvc
@inject IMapImportService MapImportSvc
@inject NotificationService NotifySvc
@inject DialogService DialogSvc
@inject IOptions<KanbanModuleOptions> ModuleOpts

<PageTitle>看板設定</PageTitle>

@if (!CanSettings)
{
    <div style="padding:40px;text-align:center;color:#f44336">無設定權限（需要 @KanbanPermissions.Settings）</div>
    return;
}

<div style="padding:16px">
    <RadzenText TextStyle="TextStyle.H5">看板設定</RadzenText>

    <RadzenTabs>
        <Tabs>
            <RadzenTabsItem Text="設備管理">
                <div style="margin-bottom:12px">
                    <RadzenButton Text="+ 新增設備" ButtonStyle="ButtonStyle.Primary"
                                  Size="ButtonSize.Small" Click="@AddEquipment" />
                </div>
                <RadzenDataGrid @ref="_equipGrid" Data="@AllEquipment" TItem="Equipment">
                    <Columns>
                        <RadzenDataGridColumn TItem="Equipment" Property="Name" Title="名稱" />
                        <RadzenDataGridColumn TItem="Equipment" Property="Tag" Title="標籤" />
                        <RadzenDataGridColumn TItem="Equipment" Title="圖示" Width="80px">
                            <Template Context="eq">
                                <EquipmentIconRenderer Equipment="@eq" />
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="Equipment" Title="操作" Width="120px">
                            <Template Context="eq">
                                <RadzenButton Text="編輯" Size="ButtonSize.ExtraSmall"
                                              Click="@(() => EditEquipment(eq))" />
                                <RadzenButton Text="刪除" Size="ButtonSize.ExtraSmall"
                                              ButtonStyle="ButtonStyle.Danger"
                                              Click="@(() => DeleteEquipment(eq.Id))"
                                              Style="margin-left:4px" />
                            </Template>
                        </RadzenDataGridColumn>
                    </Columns>
                </RadzenDataGrid>
            </RadzenTabsItem>

            <RadzenTabsItem Text="資料來源">
                <div style="margin-bottom:12px">
                    <RadzenButton Text="+ 新增資料來源" ButtonStyle="ButtonStyle.Primary"
                                  Size="ButtonSize.Small" Click="@AddDataSource" />
                </div>
                <RadzenDataGrid @ref="_dsGrid" Data="@AllDataSources" TItem="DataSourceConfig"
                                EditMode="DataGridEditMode.Single"
                                RowUpdate="@OnDataSourceUpdate">
                    <Columns>
                        <RadzenDataGridColumn TItem="DataSourceConfig" Property="Name" Title="名稱">
                            <EditTemplate Context="ds">
                                <RadzenTextBox @bind-Value="ds.Name" Style="width:100%" />
                            </EditTemplate>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="DataSourceConfig" Property="SourceType" Title="類型" Width="80px" />
                        <RadzenDataGridColumn TItem="DataSourceConfig" Property="QueryOrPath" Title="查詢/路徑">
                            <EditTemplate Context="ds">
                                <RadzenTextArea @bind-Value="ds.QueryOrPath" Style="width:100%;height:60px" />
                            </EditTemplate>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="DataSourceConfig" Title="操作" Width="140px">
                            <Template Context="ds">
                                <RadzenButton Text="編輯" Size="ButtonSize.ExtraSmall"
                                              Click="@(() => _dsGrid?.EditRow(ds) ?? Task.CompletedTask)" />
                                <RadzenButton Text="刪除" Size="ButtonSize.ExtraSmall"
                                              ButtonStyle="ButtonStyle.Danger"
                                              Click="@(() => DeleteDataSource(ds.Id))"
                                              Style="margin-left:4px" />
                            </Template>
                            <EditTemplate Context="ds">
                                <RadzenButton Text="儲存" Size="ButtonSize.ExtraSmall"
                                              ButtonStyle="ButtonStyle.Primary"
                                              Click="@(() => _dsGrid?.UpdateRow(ds) ?? Task.CompletedTask)" />
                                <RadzenButton Text="取消" Size="ButtonSize.ExtraSmall"
                                              ButtonStyle="ButtonStyle.Light"
                                              Click="@(() => CancelDataSourceEdit(ds))"
                                              Style="margin-left:4px" />
                            </EditTemplate>
                        </RadzenDataGridColumn>
                    </Columns>
                </RadzenDataGrid>
            </RadzenTabsItem>

            <RadzenTabsItem Text="圖示上傳">
                <div style="display:flex;gap:20px;flex-wrap:wrap;align-items:flex-start;padding:4px 0">

                    <!-- Step 1: Upload -->
                    <RadzenCard Style="min-width:340px;max-width:420px">
                        <RadzenText TextStyle="TextStyle.Subtitle1" Style="margin-bottom:12px">① 上傳圖示</RadzenText>

                        <InputFile OnChange="@OnIconFileSelected"
                                   accept=".png,.jpg,.jpeg,.svg"
                                   style="color:#aaa;width:100%" />

                        @if (!string.IsNullOrEmpty(_localPreviewUrl))
                        {
                            <div style="display:flex;align-items:center;gap:10px;margin-top:12px;
                                        padding:8px;background:rgba(255,255,255,.05);border-radius:4px">
                                <img src="@_localPreviewUrl" alt="預覽"
                                     style="width:48px;height:48px;object-fit:contain" />
                                <span style="color:#aaa;font-size:0.85em">選取預覽（尚未上傳至伺服器）</span>
                            </div>
                        }

                        <RadzenButton Text="上傳" ButtonStyle="ButtonStyle.Primary"
                                      Style="margin-top:10px;width:100%"
                                      Disabled="@(_iconFileBytes == null)"
                                      Click="@DoIconUpload" />

                        @if (!string.IsNullOrEmpty(IconUploadResult))
                        {
                            <div style="margin-top:12px;padding:10px;border-radius:4px;
                                        border:1px solid rgba(76,175,80,.4);background:rgba(76,175,80,.08)">
                                <div style="display:flex;align-items:center;gap:10px">
                                    <img src="@IconUploadResult" alt="已上傳圖示"
                                         style="width:48px;height:48px;object-fit:contain;
                                                background:rgba(255,255,255,.06);border-radius:4px;padding:4px" />
                                    <div style="flex:1;min-width:0">
                                        <div style="color:#4caf50;font-size:0.82em;font-weight:500;margin-bottom:2px">
                                            ✔ 上傳成功
                                        </div>
                                        <div style="color:#aaa;font-size:0.75em;word-break:break-all">
                                            @IconUploadResult
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </RadzenCard>

                    <!-- Step 2: Assign to equipment (only shown after upload) -->
                    @if (!string.IsNullOrEmpty(IconUploadResult))
                    {
                        <RadzenCard Style="min-width:280px;max-width:360px">
                            <RadzenText TextStyle="TextStyle.Subtitle1" Style="margin-bottom:8px">② 套用到設備</RadzenText>
                            <p style="color:#aaa;font-size:0.85em;margin:0 0 12px">
                                選擇要套用此圖示的設備
                            </p>

                            <RadzenDropDown @bind-Value="_assignTargetId"
                                            Data="@AllEquipment"
                                            TextProperty="Name"
                                            ValueProperty="Id"
                                            TValue="int"
                                            Placeholder="選擇設備..."
                                            Style="width:100%" />

                            @if (_assignTargetId > 0)
                            {
                                var targetEq = AllEquipment.FirstOrDefault(e => e.Id == _assignTargetId);
                                if (targetEq != null)
                                {
                                    <div style="display:flex;align-items:center;gap:8px;margin-top:10px;
                                                padding:8px;background:rgba(255,255,255,.04);border-radius:4px">
                                        <span style="color:#aaa;font-size:0.82em">目前：</span>
                                        <EquipmentIconRenderer Equipment="@targetEq" />
                                        <span style="color:#aaa;font-size:0.82em">→</span>
                                        <img src="@IconUploadResult" alt="新圖示"
                                             style="width:1.6em;height:1.6em;object-fit:contain" />
                                        <span style="color:#aaa;font-size:0.82em">@targetEq.Name</span>
                                    </div>
                                }
                            }

                            <RadzenButton Text="套用到設備" ButtonStyle="ButtonStyle.Success"
                                          Style="margin-top:10px;width:100%"
                                          Disabled="@(_assignTargetId == 0)"
                                          Click="@AssignIconToEquipment" />
                        </RadzenCard>
                    }

                </div>
            </RadzenTabsItem>

            <RadzenTabsItem Text="地圖管理">
                <MapImportPanel OnImported="@OnMapImported" />
                <div style="margin-top:16px">
                    <RadzenText TextStyle="TextStyle.Subtitle1">已匯入地圖</RadzenText>
                    <RadzenDataGrid Data="@AllMaps" TItem="FactoryMap" Style="margin-top:8px">
                        <Columns>
                            <RadzenDataGridColumn TItem="FactoryMap" Property="Name" Title="名稱" />
                            <RadzenDataGridColumn TItem="FactoryMap" Property="FormatType" Title="格式" Width="80px" />
                            <RadzenDataGridColumn TItem="FactoryMap" Property="CreatedAt" Title="建立時間"
                                                  FormatString="{0:yyyy-MM-dd}" Width="100px" />
                            <RadzenDataGridColumn TItem="FactoryMap" Title="操作" Width="80px">
                                <Template Context="m">
                                    <RadzenButton Text="刪除" Size="ButtonSize.ExtraSmall"
                                                  ButtonStyle="ButtonStyle.Danger"
                                                  Click="@(() => DeleteMap(m.Id))" />
                                </Template>
                            </RadzenDataGridColumn>
                        </Columns>
                    </RadzenDataGrid>
                </div>
            </RadzenTabsItem>
        </Tabs>
    </RadzenTabs>
</div>

@code {
    private bool CanSettings;
    private List<Equipment> AllEquipment = new();
    private List<DataSourceConfig> AllDataSources = new();
    private List<FactoryMap> AllMaps = new();
    private RadzenDataGrid<Equipment>? _equipGrid;
    private RadzenDataGrid<DataSourceConfig>? _dsGrid;
    private byte[]? _iconFileBytes;
    private string _iconFileName = string.Empty;
    private string IconUploadResult = string.Empty;
    private string _localPreviewUrl = string.Empty;
    private int _assignTargetId;

    protected override async Task OnInitializedAsync()
    {
        CanSettings = await PermSvc.HasPermissionAsync(KanbanPermissions.Settings);
        if (!CanSettings) return;
        await LoadAll();
    }

    private async Task LoadAll()
    {
        AllEquipment   = (await EquipmentSvc.GetAllEquipmentAsync()).ToList();
        AllDataSources = (await EquipmentSvc.GetAllDataSourceConfigsAsync()).ToList();
        AllMaps        = (await MapImportSvc.GetAllAsync()).ToList();
    }

    private Task AddEquipment() => OpenEquipmentDialog(new Equipment());

    private Task EditEquipment(Equipment eq) => OpenEquipmentDialog(eq);

    private async Task OpenEquipmentDialog(Equipment eq)
    {
        var saved = await DialogSvc.OpenAsync<EquipmentEditDialog>(
            eq.Id == 0 ? "新增設備" : "編輯設備",
            new Dictionary<string, object> { { "Equipment", eq } },
            new DialogOptions { Width = "480px", CloseDialogOnOverlayClick = false });
        if (saved is true)
        {
            AllEquipment = (await EquipmentSvc.GetAllEquipmentAsync()).ToList();
            await (_equipGrid?.Reload() ?? Task.CompletedTask);
        }
    }

    private async Task CancelDataSourceEdit(DataSourceConfig ds)
    {
        _dsGrid?.CancelEditRow(ds);
        if (ds.Id == 0)
        {
            AllDataSources.Remove(ds);
            await (_dsGrid?.Reload() ?? Task.CompletedTask);
        }
    }

    private async Task DeleteEquipment(int id)
    {
        try
        {
            await EquipmentSvc.DeleteEquipmentAsync(id);
            AllEquipment.RemoveAll(e => e.Id == id);
            await (_equipGrid?.Reload() ?? Task.CompletedTask);
        }
        catch (Exception ex)
        {
            NotifySvc.Notify(NotificationSeverity.Error, "刪除設備失敗", ex.Message);
        }
    }

    private async Task AddDataSource()
    {
        var ds = new DataSourceConfig { Name = "新資料來源" };
        AllDataSources.Insert(0, ds);
        await (_dsGrid?.Reload() ?? Task.CompletedTask);
        if (_dsGrid != null)
            await _dsGrid.EditRow(ds);
    }

    private async Task DeleteDataSource(int id)
    {
        try
        {
            await EquipmentSvc.DeleteDataSourceConfigAsync(id);
            AllDataSources.RemoveAll(d => d.Id == id);
            await (_dsGrid?.Reload() ?? Task.CompletedTask);
        }
        catch (Exception ex)
        {
            NotifySvc.Notify(NotificationSeverity.Error, "刪除資料來源失敗", ex.Message);
        }
    }

    private async Task OnDataSourceUpdate(DataSourceConfig ds)
    {
        try
        {
            await EquipmentSvc.SaveDataSourceConfigAsync(ds);
            await LoadAll();
            await (_dsGrid?.Reload() ?? Task.CompletedTask);
        }
        catch (Exception ex)
        {
            NotifySvc.Notify(NotificationSeverity.Error, "儲存資料來源失敗", ex.Message);
        }
    }

    private async Task OnIconFileSelected(InputFileChangeEventArgs args)
    {
        var file         = args.File;
        _iconFileBytes   = null;
        _iconFileName    = string.Empty;
        IconUploadResult = string.Empty;
        _localPreviewUrl = string.Empty;
        _assignTargetId  = 0;
        try
        {
            // Read into memory immediately — IBrowserFile JS reference becomes invalid after re-render
            await using var src = file.OpenReadStream(maxAllowedSize: ModuleOpts.Value.IconUploadMaxBytes);
            using var ms        = new MemoryStream();
            await src.CopyToAsync(ms);
            _iconFileBytes   = ms.ToArray();
            _iconFileName    = file.Name;
            var mime         = file.ContentType ?? "image/png";
            _localPreviewUrl = $"data:{mime};base64,{Convert.ToBase64String(_iconFileBytes)}";
        }
        catch (Exception ex)
        {
            NotifySvc.Notify(NotificationSeverity.Error, "讀取圖示失敗", ex.Message);
        }
    }

    private async Task DoIconUpload()
    {
        if (_iconFileBytes == null || string.IsNullOrEmpty(_iconFileName)) return;
        try
        {
            using var stream = new MemoryStream(_iconFileBytes);
            IconUploadResult = await IconSvc.UploadAsync(stream, _iconFileName);
            _localPreviewUrl = string.Empty;
            _iconFileBytes   = null;
            _iconFileName    = string.Empty;
            _assignTargetId  = 0;
            StateHasChanged();
            NotifySvc.Notify(NotificationSeverity.Success, "圖示已上傳");
        }
        catch (Exception ex)
        {
            NotifySvc.Notify(NotificationSeverity.Error, "上傳圖示失敗", ex.Message);
        }
    }

    private async Task AssignIconToEquipment()
    {
        var eq = AllEquipment.FirstOrDefault(e => e.Id == _assignTargetId);
        if (eq == null || string.IsNullOrEmpty(IconUploadResult)) return;
        try
        {
            eq.IconType  = IconType.CustomImage;
            eq.IconValue = IconUploadResult;
            await EquipmentSvc.UpdateEquipmentAsync(eq);
            AllEquipment = (await EquipmentSvc.GetAllEquipmentAsync()).ToList();
            await (_equipGrid?.Reload() ?? Task.CompletedTask);
            NotifySvc.Notify(NotificationSeverity.Success, "圖示已套用", $"已將圖示套用至「{eq.Name}」");
            _assignTargetId = 0;
        }
        catch (Exception ex)
        {
            NotifySvc.Notify(NotificationSeverity.Error, "套用圖示失敗", ex.Message);
        }
    }

    private async Task OnMapImported(FactoryMap map)
    {
        try
        {
            AllMaps = (await MapImportSvc.GetAllAsync()).ToList();
        }
        catch { }
    }

    private async Task DeleteMap(int id)
    {
        try
        {
            await MapImportSvc.DeleteAsync(id);
            AllMaps.RemoveAll(m => m.Id == id);
        }
        catch (Exception ex)
        {
            NotifySvc.Notify(NotificationSeverity.Error, "刪除地圖失敗", ex.Message);
        }
    }
}
