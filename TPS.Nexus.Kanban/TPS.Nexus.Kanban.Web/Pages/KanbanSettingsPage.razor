                $"地圖「{name}」已有版面配置版本，無法刪除。\n請先清除該地圖的所有版面版本，再執行刪除。",
                "無法刪除地圖",
                new AlertOptions { OkButtonText = "確定" });
            return;
        }

        var confirmed = await DialogSvc.Confirm(
            $"確定要刪除地圖「{name}」嗎？此操作無法復原。",
            "刪除地圖",
            new ConfirmOptions { OkButtonText = "刪除", CancelButtonText = "取消" });
        if (confirmed != true) return;

        try
        {
            await MapImportSvc.DeleteAsync(id);
            try { await AuditSvc.LogDeleteAsync("地圖", id, name, CurrentUser.GetCurrentUser()); } catch { }
            AllMaps.RemoveAll(m => m.Id == id);
            NotifySvc.Notify(NotificationSeverity.Success, "地圖已刪除", name);
        }
        catch (Exception ex)
        {
            NotifySvc.Notify(NotificationSeverity.Error, "刪除地圖失敗", ex.Message);
        }
    }
