        "圖示"      => "icon",
        "格式"      => "formatType",
        "建立時間"  => "createdAt",
        "地圖名稱"  => "mapName",
        "資料類型"  => "dataType",
        "樓層"      => "floor",
        "區域"      => "area",
        "類型"      => "sourceType",
        "查詢/路徑" => "queryOrPath",
        "輪播"      => "carousel",
        "次序"      => "carouselOrder",
        "時間(秒)"  => "carouselSecs",
        "操作"      => "actions",
        _           => title ?? string.Empty,
    };

