            if (!string.IsNullOrEmpty(_filterIconFileName))
                q = q.Where(url => IconFileName(url).Contains(_filterIconFileName, StringComparison.OrdinalIgnoreCase));
            if (!string.IsNullOrEmpty(_filterIconFormat))
