                    (e.Name?.Contains(_equipSearch,     StringComparison.OrdinalIgnoreCase) == true) ||
                    (e.Tag?.Contains(_equipSearch,      StringComparison.OrdinalIgnoreCase) == true) ||
                    (e.Category?.Contains(_equipSearch, StringComparison.OrdinalIgnoreCase) == true) ||
                    (e.MapName?.Contains(_equipSearch,  StringComparison.OrdinalIgnoreCase) == true));
            if (!string.IsNullOrEmpty(_filterEquipName))
                q = q.Where(e => e.Name?.Contains(_filterEquipName, StringComparison.OrdinalIgnoreCase) == true);
            if (!string.IsNullOrEmpty(_filterEquipCategory))
                q = q.Where(e => e.Category?.Contains(_filterEquipCategory, StringComparison.OrdinalIgnoreCase) == true);
            if (!string.IsNullOrEmpty(_filterEquipTag))
                q = q.Where(e => e.Tag?.Contains(_filterEquipTag, StringComparison.OrdinalIgnoreCase) == true);
            if (!string.IsNullOrEmpty(_filterEquipMapName))
                q = q.Where(e => e.MapName?.Contains(_filterEquipMapName, StringComparison.OrdinalIgnoreCase) == true);
            return q;
        }
