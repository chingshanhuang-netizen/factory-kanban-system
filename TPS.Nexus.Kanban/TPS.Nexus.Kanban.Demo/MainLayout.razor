@inherits LayoutComponentBase
@inject NavigationManager Nav
@implements IDisposable

<div style="display:flex;flex-direction:column;height:100vh;overflow:hidden">
    <header class="app-header">
        <span class="app-header-title">⚙ TPS Nexus 看板系統</span>
        <span class="demo-badge">DEMO</span>
        <nav style="display:flex;gap:4px;margin-left:16px">
            <a href="/kanban/1" class="nav-link @(IsKanbanActive ? "active" : "")">
                🗺 看板地圖
            </a>
            <NavLink href="/kanban/settings" Match="NavLinkMatch.All" class="nav-link">
                ⚙ 設定管理
            </NavLink>
        </nav>
        <div style="margin-left:auto;color:#4a7a9b;font-size:11px">
            廠區一樓平面圖 &nbsp;|&nbsp; 3 台設備 &nbsp;|&nbsp; 1 個活躍警報
        </div>
    </header>
    <div style="flex:1;overflow:hidden">
        @Body
    </div>
</div>

<RadzenComponents />

@code {
    private bool IsKanbanActive
    {
        get
        {
            var path = new Uri(Nav.Uri).LocalPath;
            return path.StartsWith("/kanban/") && !path.StartsWith("/kanban/settings");
        }
    }

    protected override void OnInitialized()
    {
        Nav.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        Nav.LocationChanged -= OnLocationChanged;
    }
}
